boot_targets=spi jtag
bootcmd=run distro_bootcmd
bootcmd_jtag=echo JTAG: Trying to boot script at ${scriptaddr} && source ${scriptaddr}; echo JTAG: SCRIPT FAILED: continuing...;
bootcmd_spi=sf probe 0 0 0 && sf read ${scriptaddr} ${script_offset_f} ${script_size_f} && echo SPI flash: Loading boot script from ${scriptaddr} && source ${scriptaddr}; echo SPI flash: SCRIPT FAILED: continuing...;
bootdelay=4
script_offset_f=0xC00000
script_size_f=0x10000
scriptaddr=0x84000000
distro_bootcmd=for target in ${boot_targets}; do run bootcmd_${target}; done
