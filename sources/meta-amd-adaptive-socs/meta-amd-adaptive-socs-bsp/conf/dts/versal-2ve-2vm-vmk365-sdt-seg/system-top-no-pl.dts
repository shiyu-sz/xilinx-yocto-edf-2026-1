        ref_clk: ref-clk {
                phandle = <0xb1>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x1fca055>;
                clock-output-names = "ref_clk";
        };

        rtc_clk: rtc-clk {
                phandle = <0xcb>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x8000>;
                clock-output-names = "rtc_clk";
        };

        can0_clk: can0-clk {
                phandle = <0xc4>;
                #clock-cells = <0x0>;
                compatible = "fixed-factor-clock";
                clocks = <&versal2_clk 0x9e>;
                clock-div = <0x2>;
                clock-mult = <0x1>;
        };

        can1_clk: can1-clk {
                phandle = <0xc5>;
                #clock-cells = <0x0>;
                compatible = "fixed-factor-clock";
                clocks = <&versal2_clk 0xac>;
                clock-div = <0x2>;
                clock-mult = <0x1>;
        };

        can2_clk: can2-clk {
                phandle = <0xc6>;
                #clock-cells = <0x0>;
                compatible = "fixed-factor-clock";
                clocks = <&versal2_clk 0xc1>;
                clock-div = <0x2>;
                clock-mult = <0x1>;
        };

        can3_clk: can3-clk {
                phandle = <0xc7>;
                #clock-cells = <0x0>;
                compatible = "fixed-factor-clock";
                clocks = <&versal2_clk 0xc6>;
                clock-div = <0x2>;
                clock-mult = <0x1>;
        };

        clk50: clk50 {
                phandle = <0xbe>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x2faf080>;
        };

        clk150: clk150 {
                phandle = <0xc9>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x8f0d180>;
        };

        clk250: clk250 {
                phandle = <0xca>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0xee6b280>;
        };

        clk256: clk256 {
                phandle = <0xd0>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0xf424000>;
        };

        ufs_ref_clk: ufs-ref-clk {
                phandle = <0xcc>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x18cba80>;
        };

        zynqmp-ipi {
                compatible = "xlnx,zynqmp-ipi-mailbox";
                interrupt-parent = <&imux>;
                interrupts = <0x0 0x39 0x4>;
                xlnx,ipi-id = <0x2>;
                #address-cells = <0x2>;
                #size-cells = <0x2>;
                ranges;

                ipi_mailbox_pmu1: mailbox@eb3f0440 {
                        phandle = <0xb2>;
                        reg = <0x0 0xeb3f0440 0x0 0x20 0x0 0xeb3f0460 0x0 0x20 0x0 0xeb3f0280 0x0 0x20 0x0 0xeb3f02a0 0x0 0x20>;
                        reg-names = "local_request_region", "local_response_region", "remote_request_region", "remote_response_region";
                        #mbox-cells = <0x1>;
                        xlnx,ipi-id = <0x1>;
                };
        };

        noc2_ddr5_ddr_memory: memory@00000000 {
                phandle = <0x4>;
                compatible = "xlnx,axi-noc2-1.1";
                xlnx,ip-name = "axi_noc2";
                device_type = "memory";
                reg = <0x0 0x0 0x0 0x80000000>;
                memory_type = "memory";
        };

        ps_wizard_0_ps11_0_ocm_ram_0_memory: memory@BBF00000 {
                phandle = <0xb>;
                compatible = "xlnx,ocm-ram-11.0", "mmio-sram";
                xlnx,ip-name = "ocm_ram";
                device_type = "memory";
                memory_type = "memory";
                reg = <0x0 0xbbf00000 0x0 0x80000>;
        };

        ps_wizard_0_ps11_0_ocm_ram_1_memory: memory@BBF80000 {
                phandle = <0xc>;
                compatible = "xlnx,ocm-ram-11.0", "mmio-sram";
                xlnx,ip-name = "ocm_ram";
                device_type = "memory";
                memory_type = "memory";
                reg = <0x0 0xbbf80000 0x0 0x80000>;
        };

        chosen {
                stdout-path = "serial1:115200n8";
                bootargs = "earlycon=pl011,mmio32,0xf1930000 console=ttyAMA1,115200";
        };

        reserved-memory {
                #address-cells = <0x2>;
                #size-cells = <0x2>;
                ranges;

                res: memory@0 {
                        phandle = <0x253>;
                        no-map;
                        reg = <0x0 0x0 0x0 0x20000000>;
                };
        };

        pwm-fan {
                compatible = "pwm-fan";
                pwms = <&ttc0 0x2 0x9c40 0x1>;
        };

        usb_hub_delay: enable-delay {
                phandle = <0xcd>;
                compatible = "gpio-delay";
                #gpio-cells = <0x3>;
                gpio-controller;
                gpios = <&gpio0 0xe 0x1>;
        };

        vdd_usb_hub: regulator-vdd-usb-hub {
                phandle = <0xce>;
                compatible = "regulator-fixed";
                regulator-name = "vdd_usb_hub";
                regulator-min-microvolt = <0x325aa0>;
                regulator-max-microvolt = <0x325aa0>;
                regulator-always-on;
                regulator-boot-on;
        };

        vdd2_usb_hub: regulator-vdd2-usb-hub {
                phandle = <0xcf>;
                compatible = "regulator-fixed";
                regulator-name = "vdd2_usb_hub";
                regulator-min-microvolt = <0x124f80>;
                regulator-max-microvolt = <0x124f80>;
                regulator-always-on;
                regulator-boot-on;
        };

        __symbols__ {
                cpus_a78 = "/cpus-a78@0";
                cortexa78_0 = "/cpus-a78@0/cpu@0";
                l2_00 = "/cpus-a78@0/cpu@0/l2-cache";
                cortexa78_1 = "/cpus-a78@0/cpu@100";
                l2_01 = "/cpus-a78@0/cpu@100/l2-cache";
                cortexa78_2 = "/cpus-a78@0/cpu@10000";
                l2_10 = "/cpus-a78@0/cpu@10000/l2-cache";
                cortexa78_3 = "/cpus-a78@0/cpu@10100";
                l2_11 = "/cpus-a78@0/cpu@10100/l2-cache";
                cortexa78_4 = "/cpus-a78@0/cpu@20000";
                l2_20 = "/cpus-a78@0/cpu@20000/l2-cache";
                cortexa78_5 = "/cpus-a78@0/cpu@20100";
                l2_21 = "/cpus-a78@0/cpu@20100/l2-cache";
                cortexa78_6 = "/cpus-a78@0/cpu@30000";
