        aliases {
                serial0 = "/axi/serial@f1920000";
                serial1 = "/axi/serial@f1930000";
                mmc0 = "/axi/mmc@f1040000";
                mmc1 = "/axi/mmc@f1050000";
                i2c0 = "/axi/i2c@f1940000";
                i2c1 = "/axi/i2c@f1950000";
                i2c2 = "/axi/i2c@f1960000";
                i2c3 = "/axi/i2c@f1970000";
                i2c4 = "/axi/i2c@f1980000";
                i2c5 = "/axi/i2c@f1990000";
                i2c6 = "/axi/i2c@f19a0000";
                i2c7 = "/axi/i2c@f19b0000";
                i2c8 = "/axi/i2c@f1000000";
                spi0 = "/axi/spi@f1010000";
                spi1 = "/axi/spi@f1030000";
                spi2 = "/axi/spi@f19c0000";
                spi3 = "/axi/spi@f19d0000";
                serial2 = "/axi/coresight@f0800000";
                ethernet0 = "/axi/ethernet@f1a70000";
                nvmem0 = "/axi/i2c@f1950000/i2c-arbitrator@72/i2c-arb/eeprom@54";
        };

        firmware {

                psci: psci {
                        phandle = <0xf3>;
                        compatible = "arm,psci-1.0";
                        method = "smc";
                };

                versal2_firmware: versal2-firmware {
                        phandle = <0x91>;
                        compatible = "xlnx,versal2-firmware";
                        bootph-all;
                        method = "smc";
                        #power-domain-cells = <0x1>;

                        versal2_reset: reset-controller {
                                phandle = <0xb9>;
                                compatible = "xlnx,versal-reset";
                                #reset-cells = <0x1>;
                        };

                        versal2_clk: clock-controller {
                                phandle = <0x83>;
                                #clock-cells = <0x1>;
                                compatible = "xlnx,versal2-clk";
                                bootph-all;
                                clocks = <&ref_clk>,
                                 <&ref_clk>;
                                clock-names = "ref", "pl_alt_ref";
                        };

                        versal_net_power: zynqmp-power {
                                phandle = <0xf4>;
                                compatible = "xlnx,zynqmp-power";
                                interrupt-parent = <&imux>;
                                interrupts = <0x0 0x39 0x4>;
                                mboxes = <&ipi_mailbox_pmu1 0x0>,
                                 <&ipi_mailbox_pmu1 0x1>;
                                mbox-names = "tx", "rx";
                        };

                        versal_sec_cfg: versal-sec-cfg {
                                phandle = <0xf5>;
                                compatible = "xlnx,versal-sec-cfg";
                                #address-cells = <0x1>;
                                #size-cells = <0x1>;

                                bbram_zeroize: bbram-zeroize@4 {
                                        phandle = <0xf6>;
                                        reg = <0x4 0x4>;
                                };

                                bbram_key: bbram-key@10 {
                                        phandle = <0xf7>;
                                        reg = <0x10 0x20>;
                                };

                                bbram_usr: bbram-usr@30 {
                                        phandle = <0xf8>;
                                        reg = <0x30 0x4>;
                                };

                                bbram_lock: bbram-lock@48 {
                                        phandle = <0xf9>;
                                        reg = <0x48 0x4>;
                                };

                                user_key0: user-key@110 {
                                        phandle = <0xfa>;
                                        reg = <0x110 0x20>;
                                };

                                user_key1: user-key@130 {
                                        phandle = <0xfb>;
                                        reg = <0x130 0x20>;
                                };

                                user_key2: user-key@150 {
                                        phandle = <0xfc>;
                                        reg = <0x150 0x20>;
                                };

                                user_key3: user-key@170 {
                                        phandle = <0xfd>;
                                        reg = <0x170 0x20>;
                                };

                                user_key4: user-key@190 {
                                        phandle = <0xfe>;
                                        reg = <0x190 0x20>;
                                };

                                user_key5: user-key@1b0 {
                                        phandle = <0xff>;
                                        reg = <0x1b0 0x20>;
                                };

                                user_key6: user-key@1d0 {
                                        phandle = <0x100>;
                                        reg = <0x1d0 0x20>;
                                };

                                user_key7: user-key@1f0 {
                                        phandle = <0x101>;
                                        reg = <0x1f0 0x20>;
                                };
                        };
                };
        };

        fpga: fpga-region {
                phandle = <0x102>;
                compatible = "fpga-region";
                fpga-mgr = <&versal_fpga>;
                #address-cells = <0x2>;
                #size-cells = <0x2>;
        };

        timer: timer {
                phandle = <0x103>;
                compatible = "arm,armv8-timer";
                interrupts = <0x1 0xd 0x4 0x1 0xe 0x4 0x1 0xb 0x4 0x1 0xa 0x4>;
        };

        versal_fpga: versal-fpga {
                phandle = <0xb3>;
                compatible = "xlnx,versal-fpga";
        };

        amba_apu: apu-bus {
                phandle = <0x3>;
                compatible = "simple-bus";
                #address-cells = <0x2>;
                #size-cells = <0x2>;
                ranges;
                interrupt-parent = <&gic_a78>;
                u-boot,dm-pre-reloc;

                gic_a78: interrupt-controller@e2000000 {
                        phandle = <0xe>;
                        compatible = "arm,gic-v3";
                        #interrupt-cells = <0x3>;
                        reg = <0x0 0xe2000000 0x0 0x10000 0x0 0xe2060000 0x0 0x200000>;
                        interrupt-controller;
                        interrupt-parent = <&gic_a78>;
                        interrupts = <0x1 0x9 0x4>;
                        #address-cells = <0x2>;
                        #size-cells = <0x2>;
                        ranges;
                        status = "okay";
                        xlnx,ip-name = "acpu_gic";
                        xlnx,name = "ps_wizard_0_ps11_0_acpu_gic";

                        its: msi-controller@e2040000 {
                                phandle = <0xd2>;
                                compatible = "arm,gic-v3-its";
                                msi-controller;
                                #msi-cells = <0x1>;
                                reg = <0x0 0xe2040000 0x0 0x20000>;
                        };
                };
        };

        amba_rpu: rpu-bus {
                phandle = <0x8c>;
                compatible = "indirect-bus";
                #address-cells = <0x2>;
                #size-cells = <0x2>;
                ranges;
                interrupt-parent = <&gic_r52>;
                u-boot,dm-pre-reloc;

                gic_r52: interrupt-controller@e2000000 {
                        phandle = <0x8f>;
                        compatible = "arm,gic-v3", "arm,gic";
                        #interrupt-cells = <0x3>;
                        interrupt-controller;
                        interrupt-parent = <&gic_r52>;
                        interrupts = <0x1 0x9 0x4>;
                        #address-cells = <0x2>;
                        #size-cells = <0x2>;
                        reg = <0x0 0xe2000000 0x0 0x10000 0x0 0xe2100000 0x0 0x80000>;
                        status = "okay";
                        xlnx,ip-name = "rcpu_gic";
                        xlnx,name = "ps_wizard_0_ps11_0_rcpu_gic";
                };
        };

        sensor0: versal-thermal-sensor {
                phandle = <0xb4>;
                compatible = "xlnx,versal-thermal";
                #thermal-sensor-cells = <0x1>;
                io-channels = <&sysmon0 0x0>;
                io-channel-names = "sysmon-temp-channel";
        };

        thermal-zones {

                versal_thermal: versal-thermal {
                        phandle = <0x104>;
                        polling-delay-passive = <0xfa>;
                        polling-delay = <0x3e8>;
                        thermal-sensors = <&sensor0 0x0>;

                        trips {

                                temp_alert: temp-alert {
                                        phandle = <0x105>;
                                        temperature = <0x11170>;
                                        hysteresis = <0x0>;
                                        type = "passive";
                                };

                                ot_crit: ot-crit {
                                        phandle = <0x106>;
                                        temperature = <0x1e848>;
                                        hysteresis = <0x0>;
                                        type = "critical";
                                };
                        };

                        cooling-maps {
                        };
                };

                versal_thermal_aie: versal-aie-thermal {
                        phandle = <0x107>;
                        polling-delay-passive = <0xfa>;
                        polling-delay = <0x3e8>;
                        thermal-sensors = <&sensor0 0x1>;

                        trips {

                                temp_alert_aie: temp-alert-aie {
                                        phandle = <0x108>;
                                        temperature = <0x11170>;
                                        hysteresis = <0x0>;
                                        type = "passive";
                                };

                                ot_crit_aie: ot-crit-aie {
                                        phandle = <0x109>;
                                        temperature = <0x1e848>;
                                        hysteresis = <0x0>;
                                        type = "critical";
                                };
                        };

                        cooling-maps {
                        };
                };
        };

        amba: axi {
                phandle = <0x2>;
                compatible = "simple-bus";
                bootph-all;
                #address-cells = <0x2>;
                #size-cells = <0x2>;
                ranges;
                interrupt-parent = <&imux>;

                imux: interrupt-multiplex {
                        phandle = <0x1>;
                        compatible = "interrupt-multiplex";
                        #address-cells = <0x0>;
                        #interrupt-cells = <0x3>;
                        interrupt-controller;
                        interrupt-parent = <&gic_a78>,
                         <&gic_r52>;
                        interrupt-map-mask = <0x0 0xffff 0x0>;
                        interrupt-map = <0x0 0x14 0x0 &gic_a78 0x0 0x14 0x4>,
                         <0x0 0x13 0x0 &gic_a78 0x0 0x13 0x4>,
                         <0x0 0x15 0x0 &gic_a78 0x0 0x15 0x4>,
