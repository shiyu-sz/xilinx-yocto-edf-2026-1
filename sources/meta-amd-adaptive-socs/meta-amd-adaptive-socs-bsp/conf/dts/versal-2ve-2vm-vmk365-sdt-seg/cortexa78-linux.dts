/dts-v1/;
/ {
        compatible = "amd,versal2-vmk365-revA", "amd,versal2-vmk365", "amd,versal2";
        model = "AMD Versal VMK365 revA";
        #address-cells = <0x2>;
        #size-cells = <0x2>;
        interrupt-parent = <&gic>;
        device_id = "xc2vm3654";
        variant = "Versal_2VE_2VM_Small";
        xlnx,ddrmc5-debug-elf = "false";
        xlnx,ddrmc5-i2c-master = "PMC";
        slrcount = <0x1>;
        family = "Versal_2VE_2VM";
        speed_grade = "1LHP";

        options {

                u-boot {
                        compatible = "u-boot,config";
                        bootscr-address = /bits/ 64 <0x78000000>;
                };
        };

        cpus_a78: cpus {
                phandle = <0xd6>;
                #address-cells = <0x1>;
                #size-cells = <0x0>;
                compatible = "cpus,cluster";
                #ranges-address-cells = <0x2>;
                #ranges-size-cells = <0x2>;

                cpu-map {

                        cluster0 {

                                core0 {
                                        cpu = <&cortexa78_0>;
                                };

                                core1 {
                                        cpu = <&cortexa78_1>;
                                };
                        };

                        cluster1 {

                                core0 {
                                        cpu = <&cortexa78_2>;
                                };

                                core1 {
                                        cpu = <&cortexa78_3>;
                                };
                        };

                        cluster2 {

                                core0 {
                                        cpu = <&cortexa78_4>;
                                };

                                core1 {
                                        cpu = <&cortexa78_5>;
                                };
                        };

                        cluster3 {

                                core0 {
                                        cpu = <&cortexa78_6>;
                                };

                                core1 {
                                        cpu = <&cortexa78_7>;
                                };
                        };
                };

                cortexa78_0: cpu@0 {
                        phandle = <0x78>;
                        compatible = "arm,cortex-a78";
                        device_type = "cpu";
                        enable-method = "psci";
                        reg = <0x0>;
                        cpu-idle-states = <&CPU_RETENTION_0>;
                        operating-points-v2 = <&cpu_opp_table>;
                        d-cache-size = <0x10000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x100>;
                        i-cache-size = <0x10000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        next-level-cache = <&l2_00>;
                        clocks = <&versal2_clk 0x98>;
                        xlnx,timestamp-clk-freq = <0x5f5dd19>;
                        xlnx,pss-ref-clk-freq = <0x1fc9350>;
                        stamp-frequency = <0x5f5dd19>;
                        xlnx,ip-name = "cortexa78";
                        xlnx,cluster-number = <0x0>;
                        xlnx,cpu-clk-freq-hz = <0x80261194>;
                        cpu-frequency = <0x80261194>;
                        bus-handle = <0x2>;

                        l2_00: l2-cache {
                                phandle = <0x82>;
                                compatible = "cache";
                                cache-level = <0x2>;
                                cache-size = <0x80000>;
                                cache-line-size = <0x40>;
                                cache-sets = <0x400>;
                                cache-unified;
                                next-level-cache = <&l3_0>;
                        };
                };

                cortexa78_1: cpu@100 {
                        phandle = <0x79>;
                        compatible = "arm,cortex-a78";
                        device_type = "cpu";
                        enable-method = "psci";
                        reg = <0x100>;
                        cpu-idle-states = <&CPU_RETENTION_0>;
                        operating-points-v2 = <&cpu_opp_table>;
                        d-cache-size = <0x10000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x100>;
                        i-cache-size = <0x10000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        next-level-cache = <&l2_00>;
                        clocks = <&versal2_clk 0x98>;
                        xlnx,timestamp-clk-freq = <0x5f5dd19>;
                        xlnx,pss-ref-clk-freq = <0x1fc9350>;
                        stamp-frequency = <0x5f5dd19>;
                        xlnx,ip-name = "cortexa78";
                        xlnx,cluster-number = <0x0>;
                        xlnx,cpu-clk-freq-hz = <0x80261194>;
                        cpu-frequency = <0x80261194>;
                        bus-handle = <0x2>;

                        l2_01: l2-cache {
                                phandle = <0xd7>;
                                compatible = "cache";
                                cache-level = <0x2>;
                                cache-size = <0x80000>;
                                cache-line-size = <0x40>;
                                cache-sets = <0x400>;
                                cache-unified;
                                next-level-cache = <&l3_0>;
                        };
                };

                cortexa78_2: cpu@10000 {
                        phandle = <0x7a>;
                        compatible = "arm,cortex-a78";
                        device_type = "cpu";
                        enable-method = "psci";
                        reg = <0x10000>;
                        cpu-idle-states = <&CPU_RETENTION_0>;
                        operating-points-v2 = <&cpu_opp_table>;
                        d-cache-size = <0x10000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x100>;
                        i-cache-size = <0x10000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        next-level-cache = <&l2_10>;
                        clocks = <&versal2_clk 0x9b>;
                        xlnx,timestamp-clk-freq = <0x5f5dd19>;
                        xlnx,pss-ref-clk-freq = <0x1fc9350>;
                        stamp-frequency = <0x5f5dd19>;
                        xlnx,ip-name = "cortexa78";
                        xlnx,cluster-number = <0x0>;
                        xlnx,cpu-clk-freq-hz = <0x80261194>;
                        cpu-frequency = <0x80261194>;
                        bus-handle = <0x2>;

                        l2_10: l2-cache {
                                phandle = <0x85>;
                                compatible = "cache";
                                cache-level = <0x2>;
                                cache-size = <0x80000>;
                                cache-line-size = <0x40>;
                                cache-sets = <0x400>;
                                cache-unified;
                                next-level-cache = <&l3_1>;
                        };
                };

                cortexa78_3: cpu@10100 {
                        phandle = <0x7b>;
                        compatible = "arm,cortex-a78";
                        device_type = "cpu";
                        enable-method = "psci";
                        reg = <0x10100>;
                        cpu-idle-states = <&CPU_RETENTION_0>;
                        operating-points-v2 = <&cpu_opp_table>;
                        d-cache-size = <0x10000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x100>;
                        i-cache-size = <0x10000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        next-level-cache = <&l2_10>;
                        clocks = <&versal2_clk 0x9b>;
                        xlnx,timestamp-clk-freq = <0x5f5dd19>;
                        xlnx,pss-ref-clk-freq = <0x1fc9350>;
                        stamp-frequency = <0x5f5dd19>;
                        xlnx,ip-name = "cortexa78";
                        xlnx,cluster-number = <0x0>;
                        xlnx,cpu-clk-freq-hz = <0x80261194>;
                        cpu-frequency = <0x80261194>;
                        bus-handle = <0x2>;

                        l2_11: l2-cache {
                                phandle = <0xd8>;
                                compatible = "cache";
                                cache-level = <0x2>;
                                cache-size = <0x80000>;
                                cache-line-size = <0x40>;
                                cache-sets = <0x400>;
                                cache-unified;
                                next-level-cache = <&l3_1>;
                        };
                };

                cortexa78_4: cpu@20000 {
                        phandle = <0x7c>;
                        compatible = "arm,cortex-a78";
                        device_type = "cpu";
                        enable-method = "psci";
                        reg = <0x20000>;
                        cpu-idle-states = <&CPU_RETENTION_0>;
                        operating-points-v2 = <&cpu_opp_table>;
                        d-cache-size = <0x10000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x100>;
                        i-cache-size = <0x10000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        next-level-cache = <&l2_20>;
                        clocks = <&versal2_clk 0x9a>;

                        l2_20: l2-cache {
                                phandle = <0x87>;
                                compatible = "cache";
                                cache-level = <0x2>;
                                cache-size = <0x80000>;
                                cache-line-size = <0x40>;
                                cache-sets = <0x400>;
                                cache-unified;
                                next-level-cache = <&l3_2>;
                        };
                };

                cortexa78_5: cpu@20100 {
                        phandle = <0x7d>;
                        compatible = "arm,cortex-a78";
                        device_type = "cpu";
                        enable-method = "psci";
                        reg = <0x20100>;
                        cpu-idle-states = <&CPU_RETENTION_0>;
                        operating-points-v2 = <&cpu_opp_table>;
                        d-cache-size = <0x10000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x100>;
                        i-cache-size = <0x10000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        next-level-cache = <&l2_20>;
                        clocks = <&versal2_clk 0x9a>;

                        l2_21: l2-cache {
                                phandle = <0xd9>;
                                compatible = "cache";
                                cache-level = <0x2>;
                                cache-size = <0x80000>;
                                cache-line-size = <0x40>;
                                cache-sets = <0x400>;
                                cache-unified;
                                next-level-cache = <&l3_2>;
                        };
                };

                cortexa78_6: cpu@30000 {
                        phandle = <0x7e>;
                        compatible = "arm,cortex-a78";
                        device_type = "cpu";
                        enable-method = "psci";
                        reg = <0x30000>;
                        cpu-idle-states = <&CPU_RETENTION_0>;
                        operating-points-v2 = <&cpu_opp_table>;
                        d-cache-size = <0x10000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x100>;
                        i-cache-size = <0x10000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        next-level-cache = <&l2_30>;
                        clocks = <&versal2_clk 0x99>;

                        l2_30: l2-cache {
                                phandle = <0x89>;
                                compatible = "cache";
                                cache-level = <0x2>;
                                cache-size = <0x80000>;
                                cache-line-size = <0x40>;
                                cache-sets = <0x400>;
                                cache-unified;
                                next-level-cache = <&l3_3>;
                        };
                };

                cortexa78_7: cpu@30100 {
                        phandle = <0x7f>;
                        compatible = "arm,cortex-a78";
                        device_type = "cpu";
                        enable-method = "psci";
                        reg = <0x30100>;
                        cpu-idle-states = <&CPU_RETENTION_0>;
                        operating-points-v2 = <&cpu_opp_table>;
                        d-cache-size = <0x10000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x100>;
                        i-cache-size = <0x10000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        next-level-cache = <&l2_30>;
                        clocks = <&versal2_clk 0x99>;

                        l2_31: l2-cache {
                                phandle = <0xda>;
                                compatible = "cache";
                                cache-level = <0x2>;
                                cache-size = <0x80000>;
                                cache-line-size = <0x40>;
                                cache-sets = <0x400>;
                                cache-unified;
                                next-level-cache = <&l3_3>;
                        };
                };

                l3_0: l3-0-cache {
                        phandle = <0x84>;
                        compatible = "cache";
                        cache-level = <0x3>;
                        cache-size = <0x100000>;
                        cache-line-size = <0x40>;
                        cache-sets = <0x400>;
                        cache-unified;
                        next-level-cache = <&llc>;
                };

                l3_1: l3-1-cache {
                        phandle = <0x86>;
                        compatible = "cache";
                        cache-level = <0x3>;
                        cache-size = <0x100000>;
                        cache-line-size = <0x40>;
                        cache-sets = <0x400>;
                        cache-unified;
                        next-level-cache = <&llc>;
                };

                l3_2: l3-2-cache {
                        phandle = <0x88>;
                        compatible = "cache";
                        cache-level = <0x3>;
                        cache-size = <0x100000>;
                        cache-line-size = <0x40>;
                        cache-sets = <0x400>;
                        cache-unified;
                        next-level-cache = <&llc>;
                };

                l3_3: l3-3-cache {
                        phandle = <0x8a>;
                        compatible = "cache";
                        cache-level = <0x3>;
                        cache-size = <0x100000>;
                        cache-line-size = <0x40>;
                        cache-sets = <0x400>;
                        cache-unified;
                        next-level-cache = <&llc>;
                };

                llc: l4-cache {
                        phandle = <0x8b>;
                        compatible = "cache";
                        cache-level = <0x4>;
                        cache-size = <0x400000>;
                        cache-unified;
                };

                idle-states {
                        entry-method = "psci";

                        CPU_RETENTION_0: cpu-retention-0 {
                                phandle = <0x80>;
                                compatible = "arm,idle-state";
                                arm,psci-suspend-param = <0x0>;
                                local-timer-stop;
                                entry-latency-us = <0x12c>;
                                exit-latency-us = <0x258>;
                                min-residency-us = <0x2710>;
                        };
                };
        };

        cpu_opp_table: opp-table {
                phandle = <0x81>;
                compatible = "operating-points-v2";

                opp-2150000000 {
                        opp-hz = /bits/ 64 <0x80266580>;
                        clock-latency-ns = <0x7a120>;
                        opp-microvolt = <0xf4240>;
                };

                opp-1075000000 {
                        opp-hz = /bits/ 64 <0x401332c0>;
                        clock-latency-ns = <0x7a120>;
                        opp-microvolt = <0xf4240>;
                };

                opp-716666667 {
                        opp-hz = /bits/ 64 <0x2ab7772b>;
                        clock-latency-ns = <0x7a120>;
                        opp-microvolt = <0xf4240>;
                };

                opp-537500000 {
                        opp-hz = /bits/ 64 <0x20099960>;
                        clock-latency-ns = <0x7a120>;
                        opp-microvolt = <0xf4240>;
                };
        };

        aliases {
                serial0 = "/axi/serial@f1920000";
                serial1 = "/axi/serial@f1930000";
                mmc0 = "/axi/mmc@f1040000";
                mmc1 = "/axi/mmc@f1050000";
                i2c0 = "/axi/i2c@f1940000";
                i2c1 = "/axi/i2c@f1950000";
                i2c2 = "/axi/i2c@f1960000";
                i2c3 = "/axi/i2c@f1970000";
                i2c4 = "/axi/i2c@f1980000";
                i2c5 = "/axi/i2c@f1990000";
                i2c6 = "/axi/i2c@f19a0000";
                i2c7 = "/axi/i2c@f19b0000";
                i2c8 = "/axi/i2c@f1000000";
                spi0 = "/axi/spi@f1010000";
                spi1 = "/axi/spi@f1030000";
                spi2 = "/axi/spi@f19c0000";
                spi3 = "/axi/spi@f19d0000";
                serial2 = "/axi/coresight@f0800000";
                ethernet0 = "/axi/ethernet@f1a70000";
                nvmem0 = "/axi/i2c@f1950000/i2c-arbitrator@72/i2c-arb/eeprom@54";
        };

        firmware {

                psci: psci {
                        phandle = <0xf3>;
                        compatible = "arm,psci-1.0";
                        method = "smc";
                };

                versal2_firmware: versal2-firmware {
                        phandle = <0x91>;
                        compatible = "xlnx,versal2-firmware";
                        bootph-all;
                        method = "smc";
                        #power-domain-cells = <0x1>;

                        versal2_reset: reset-controller {
                                phandle = <0xb9>;
                                compatible = "xlnx,versal-reset";
                                #reset-cells = <0x1>;
                        };

                        versal2_clk: clock-controller {
                                phandle = <0x83>;
                                #clock-cells = <0x1>;
                                compatible = "xlnx,versal2-clk";
                                bootph-all;
                                clocks = <&ref_clk>,
                                 <&ref_clk>;
                                clock-names = "ref", "pl_alt_ref";
                        };

                        versal_net_power: zynqmp-power {
                                phandle = <0xf4>;
                                compatible = "xlnx,zynqmp-power";
                                interrupt-parent = <&gic>;
                                interrupts = <0x0 0x39 0x4>;
                                mboxes = <&ipi_mailbox_pmu1 0x0>,
                                 <&ipi_mailbox_pmu1 0x1>;
                                mbox-names = "tx", "rx";
                        };

                        versal_sec_cfg: versal-sec-cfg {
                                phandle = <0xf5>;
                                compatible = "xlnx,versal-sec-cfg";
                                #address-cells = <0x1>;
                                #size-cells = <0x1>;

                                bbram_zeroize: bbram-zeroize@4 {
                                        phandle = <0xf6>;
                                        reg = <0x4 0x4>;
                                };

                                bbram_key: bbram-key@10 {
                                        phandle = <0xf7>;
                                        reg = <0x10 0x20>;
                                };

                                bbram_usr: bbram-usr@30 {
                                        phandle = <0xf8>;
                                        reg = <0x30 0x4>;
                                };

                                bbram_lock: bbram-lock@48 {
                                        phandle = <0xf9>;
                                        reg = <0x48 0x4>;
                                };

                                user_key0: user-key@110 {
                                        phandle = <0xfa>;
                                        reg = <0x110 0x20>;
                                };

                                user_key1: user-key@130 {
                                        phandle = <0xfb>;
                                        reg = <0x130 0x20>;
                                };

                                user_key2: user-key@150 {
                                        phandle = <0xfc>;
                                        reg = <0x150 0x20>;
                                };

                                user_key3: user-key@170 {
                                        phandle = <0xfd>;
                                        reg = <0x170 0x20>;
                                };

                                user_key4: user-key@190 {
                                        phandle = <0xfe>;
                                        reg = <0x190 0x20>;
                                };

                                user_key5: user-key@1b0 {
                                        phandle = <0xff>;
                                        reg = <0x1b0 0x20>;
                                };

                                user_key6: user-key@1d0 {
                                        phandle = <0x100>;
                                        reg = <0x1d0 0x20>;
                                };

                                user_key7: user-key@1f0 {
                                        phandle = <0x101>;
                                        reg = <0x1f0 0x20>;
                                };
                        };
                };
        };

        fpga: fpga-region {
                phandle = <0x102>;
                compatible = "fpga-region";
                fpga-mgr = <&versal_fpga>;
                #address-cells = <0x2>;
                #size-cells = <0x2>;
        };

        timer: timer {
                phandle = <0x103>;
                compatible = "arm,armv8-timer";
                interrupts = <0x1 0xd 0x4 0x1 0xe 0x4 0x1 0xb 0x4 0x1 0xa 0x4>;
        };

        versal_fpga: versal-fpga {
                phandle = <0xb3>;
                compatible = "xlnx,versal-fpga";
        };

        sensor0: versal-thermal-sensor {
                phandle = <0xb4>;
                compatible = "xlnx,versal-thermal";
                #thermal-sensor-cells = <0x1>;
                io-channels = <&sysmon0 0x0>;
                io-channel-names = "sysmon-temp-channel";
        };

        thermal-zones {

                versal_thermal: versal-thermal {
                        phandle = <0x104>;
                        polling-delay-passive = <0xfa>;
                        polling-delay = <0x3e8>;
                        thermal-sensors = <&sensor0 0x0>;

                        trips {

                                temp_alert: temp-alert {
                                        phandle = <0x105>;
                                        temperature = <0x11170>;
                                        hysteresis = <0x0>;
                                        type = "passive";
                                };

                                ot_crit: ot-crit {
                                        phandle = <0x106>;
                                        temperature = <0x1e848>;
                                        hysteresis = <0x0>;
                                        type = "critical";
                                };
                        };

                        cooling-maps {
                        };
                };

                versal_thermal_aie: versal-aie-thermal {
                        phandle = <0x107>;
                        polling-delay-passive = <0xfa>;
                        polling-delay = <0x3e8>;
                        thermal-sensors = <&sensor0 0x1>;

                        trips {

                                temp_alert_aie: temp-alert-aie {
                                        phandle = <0x108>;
                                        temperature = <0x11170>;
                                        hysteresis = <0x0>;
                                        type = "passive";
                                };

                                ot_crit_aie: ot-crit-aie {
                                        phandle = <0x109>;
                                        temperature = <0x1e848>;
                                        hysteresis = <0x0>;
                                        type = "critical";
                                };
                        };

                        cooling-maps {
                        };
                };
        };

        amba: axi {
                phandle = <0x2>;
                compatible = "simple-bus";
                bootph-all;
                #address-cells = <0x2>;
                #size-cells = <0x2>;
                ranges;
                interrupt-parent = <&gic>;

                mmi_gpu_slcr@ed720000 {
                        reg = <0x0 0xed720000 0x0 0x20000>;
                        no-map;
                };

                gpu_physical_memory_group_manager: physical-memory-group-manager {
                        phandle = <0xb8>;
                        compatible = "arm,physical-memory-group-manager";
                };

                gpu: gpu@ed000000 {
                        phandle = <0x43>;
                        status = "okay";
                        compatible = "arm,mali-ptm";
                        ranges;
                        #address-cells = <0x2>;
                        #size-cells = <0x2>;
                        #interrupt-cells = <0x2>;
                        xlnx,gpu-slices = <0x1>;
                        xlnx,gpu-clk-freq-mhz = <0x3b9aca00>;
                        xlnx,gpu-slice0-cores = <0x1>;
                        xlnx,gpu-slice1-cores = <0x0>;
                        xlnx,ip-name = "mmi_gpu";
                        xlnx,gpu-clk-src = "MMI_PLL";

                        gpu_interface@ed700000 {
                                compatible = "arm,mali-ptm-interface";
                                ranges = <0x0 0x0 0x0 0xed700000 0x0 0x20000>;
                                reg = <0x0 0xed700000 0x0 0x20000>;
                                #address-cells = <0x2>;
                                #size-cells = <0x2>;

                                gpu_system@0 {
                                        compatible = "arm,mali-gpu-system";
                                        reg = <0x0 0x0 0x0 0x10000>;
                                        interrupt-parent = <&gic>;
                                        interrupt-names = "PTM_UNCORRECTED_ERROR_IRQ", "PTM_DEFERRED_ERROR_IRQ";
                                        interrupts = <0x0 0xbc 0x4 0x0 0xbc 0x4>;
                                };

                                gpu_assign@10000 {
                                        compatible = "arm,mali-gpu-assign";
                                        reg = <0x0 0x10000 0x0 0x10000>;
                                };
                        };

                        gpu_interface@ed000000 {
                                compatible = "arm,mali-ptm-interface";
                                ranges = <0x0 0x0 0x0 0xed000000 0x0 0x300000>;
                                reg = <0x0 0xed000000 0x0 0x300000>;
                                #address-cells = <0x2>;
                                #size-cells = <0x2>;

                                gpu_partition_config_a_0: gpu_partition_config@20000 {
                                        phandle = <0xb5>;
                                        compatible = "arm,mali-gpu-partition-config";
                                        reg = <0x0 0x20000 0x0 0x10000>;
                                };

