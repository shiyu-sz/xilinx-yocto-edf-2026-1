                ipi_mailbox_pmu1: mailbox@eb3f0440 {
                        phandle = <0xb2>;
                        reg = <0x0 0xeb3f0440 0x0 0x20 0x0 0xeb3f0460 0x0 0x20 0x0 0xeb3f0280 0x0 0x20 0x0 0xeb3f02a0 0x0 0x20>;
                        reg-names = "local_request_region", "local_response_region", "remote_request_region", "remote_response_region";
                        #mbox-cells = <0x1>;
                        xlnx,ipi-id = <0x1>;
                };
        };

        noc2_ddr5_ddr_memory: memory@00000000 {
                phandle = <0x4>;
                compatible = "xlnx,axi-noc2-1.1";
                xlnx,ip-name = "axi_noc2";
                device_type = "memory";
                reg = <0x0 0x0 0x0 0x80000000>;
                memory_type = "memory";
        };

        chosen {
                stdout-path = "serial1:115200n8";
                bootargs = "earlycon=pl011,mmio32,0xf1930000 console=ttyAMA1,115200";
        };

        reserved-memory {
                #address-cells = <0x2>;
                #size-cells = <0x2>;
                ranges;

                res: memory@0 {
                        phandle = <0x253>;
                        no-map;
                        reg = <0x0 0x0 0x0 0x20000000>;
                };
        };

        pwm-fan {
                compatible = "pwm-fan";
                pwms = <&ttc0 0x2 0x9c40 0x1>;
        };

        usb_hub_delay: enable-delay {
                phandle = <0xcd>;
                compatible = "gpio-delay";
                #gpio-cells = <0x3>;
                gpio-controller;
                gpios = <&gpio0 0xe 0x1>;
        };

        vdd_usb_hub: regulator-vdd-usb-hub {
                phandle = <0xce>;
                compatible = "regulator-fixed";
                regulator-name = "vdd_usb_hub";
                regulator-min-microvolt = <0x325aa0>;
                regulator-max-microvolt = <0x325aa0>;
                regulator-always-on;
                regulator-boot-on;
        };

        vdd2_usb_hub: regulator-vdd2-usb-hub {
                phandle = <0xcf>;
                compatible = "regulator-fixed";
                regulator-name = "vdd2_usb_hub";
                regulator-min-microvolt = <0x124f80>;
                regulator-max-microvolt = <0x124f80>;
                regulator-always-on;
                regulator-boot-on;
        };

