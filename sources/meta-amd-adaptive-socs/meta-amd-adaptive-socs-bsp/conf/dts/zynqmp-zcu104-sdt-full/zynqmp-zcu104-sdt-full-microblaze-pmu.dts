        binman: binman {
                phandle = <0x11f>;
        };

        pss_ref_clk: pss-ref-clk {
                phandle = <0x8c>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x1fca055>;
                clock-output-names = "pss_ref_clk";
        };

        video_clk: video-clk {
                phandle = <0x8d>;
                bootph-all;
