                i2c1: i2c@ff030000 {
                        phandle = <0x48>;
                        compatible = "cdns,i2c-r1p14";
                        status = "okay";
                        interrupt-parent = <&imux>;
                        interrupts = <0x0 0x12 0x4>;
                        clock-frequency = <0x61a80>;
                        reg = <0x0 0xff030000 0x0 0x1000>;
                        #address-cells = <0x1>;
                        #size-cells = <0x0>;
                        power-domains = <&zynqmp_firmware 0x26>;
                        clocks = <&zynqmp_clk 0x3e>;
                        xlnx,i2c-reset = <0x0>;
                        xlnx,has-interrupt = <0x2faf080>;
                        xlnx,clock-freq = <0x5f5e100>;
                        xlnx,i2c-clk-freq-hz = <0x5f5e100>;
                        xlnx,ip-name = "psu_i2c";
                        xlnx,iic-board-interface = "custom";
                        xlnx,name = "psu_i2c_1";
                        pinctrl-names = "default", "gpio";
                        pinctrl-0 = <0x9a>;
                        pinctrl-1 = <0x9b>;
                        scl-gpios = <0x46 0x10 0x6>;
                        sda-gpios = <0x46 0x11 0x6>;

                        i2c-mux@74 {
                                compatible = "nxp,pca9548";
                                #address-cells = <0x1>;
                                #size-cells = <0x0>;
                                reg = <0x74>;

                                i2c@0 {
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;
                                        reg = <0x0>;

                                        eeprom: eeprom@54 {
                                                phandle = <0xd4>;
                                                compatible = "atmel,24c08";
                                                label = "eeprom_zcu104a";
                                                reg = <0x54>;
                                                #address-cells = <0x1>;
                                                #size-cells = <0x1>;
                                        };
                                };

                                i2c@1 {
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;
                                        reg = <0x1>;
                                };

                                i2c@2 {
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;
                                        reg = <0x2>;

                                        irps5401_43: irps5401@43 {
                                                phandle = <0xd5>;
                                                compatible = "infineon,irps5401";
                                                reg = <0x43>;
                                        };

                                        irps5401_44: irps5401@44 {
                                                phandle = <0xd6>;
                                                compatible = "infineon,irps5401";
                                                reg = <0x44>;
                                        };
                                };

                                i2c@4 {
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;
                                        reg = <0x4>;

                                        tca6416_u97: gpio@20 {
                                                phandle = <0x99>;
                                                compatible = "ti,tca6416";
                                                reg = <0x20>;
                                                gpio-controller;
                                                #gpio-cells = <0x2>;
                                        };
                                };

                                i2c@5 {
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;
                                        reg = <0x5>;
                                };

                                i2c@7 {
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;
                                        reg = <0x7>;
                                };
                        };
                };

