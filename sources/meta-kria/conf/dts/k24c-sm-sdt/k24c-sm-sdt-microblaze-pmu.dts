                        xlnx,clk-50-sdr-otap-dly = <0x6>;
                        xlnx,clk-50-ddr-itap-dly = <0x12>;
                        xlnx,has-power = <0x1>;
                        xlnx,clk-200-sdr-otap-dly = <0x3>;
