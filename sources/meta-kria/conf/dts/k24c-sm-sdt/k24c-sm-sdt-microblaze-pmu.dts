                };
        };

        binman: binman {
                phandle = <0x15a>;
        };

        pss_ref_clk: pss-ref-clk {
                phandle = <0x89>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x1fc9f08>;
                clock-output-names = "pss_ref_clk";
        };

        video_clk: video-clk {
                phandle = <0x8a>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x19bfcc0>;
                clock-output-names = "video_clk";
        };

        pss_alt_ref_clk: pss-alt-ref-clk {
                phandle = <0x8b>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x0>;
                clock-output-names = "pss_alt_ref_clk";
        };

        gt_crx_ref_clk: gt-crx-ref-clk {
                phandle = <0x8d>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x66ff300>;
                clock-output-names = "gt_crx_ref_clk";
        };

        aux_ref_clk: aux-ref-clk {
                phandle = <0x8c>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x19bfcc0>;
                clock-output-names = "aux_ref_clk";
        };

        rtc_clk: rtc-clk {
                phandle = <0x95>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x8000>;
                clock-output-names = "rtc_clk";
        };

        psu_ocm_ram_0_memory: memory@FFFC0000 {
                phandle = <0x7>;
                compatible = "xlnx,psu-ocm-ram-0-1.0", "mmio-sram";
                xlnx,ip-name = "psu_ocm_ram_0";
                device_type = "memory";
                memory_type = "memory";
                reg = <0x0 0xfffc0000 0x0 0x40000>;
        };

        psu_ddr_0_memory: memory@0 {
                phandle = <0xd>;
                compatible = "xlnx,psu-ddr-1.0";
                xlnx,ip-name = "psu_ddr";
                device_type = "memory";
                memory_type = "memory";
                reg = <0x0 0x0 0x0 0x7ff00000 0x0 0x7ff00000 0x0 0x100000>;
        };

        psu_qspi_linear_0_memory: memory@c0000000 {
                phandle = <0x56>;
                compatible = "xlnx,psu-qspi-linear-1.0-memory";
                xlnx,ip-name = "psu_qspi_linear";
                device_type = "memory";
                memory_type = "linear_flash";
                reg = <0x0 0xc0000000 0x0 0x20000000>;
        };

        chosen {
                bootargs = "earlycon";
                stdout-path = "serial1:115200n8";
        };

        aliases {
                serial0 = "/axi/serial@ff000000";
                spi0 = "/axi/spi@ff0f0000";
                serial1 = "/axi/serial@ff010000";
                i2c0 = "/axi/i2c@ff020000";
                i2c1 = "/axi/i2c@ff030000";
                mmc0 = "/axi/mmc@ff160000";
                mmc1 = "/axi/mmc@ff170000";
                nvmem0 = "/axi/i2c@ff030000/eeprom@50";
                nvmem1 = "/axi/i2c@ff030000/eeprom@51";
                rtc0 = "/axi/rtc@ffa60000";
                serial2 = "/dcc";
                spi1 = "/axi/spi@ff040000";
                spi2 = "/axi/spi@ff050000";
                usb0 = "/axi/usb@ff9d0000";
                usb1 = "/axi/usb@ff9e0000";
        };

        gpio-keys {
                compatible = "gpio-keys";
                autorepeat;

                key-fwuen {
                        label = "fwuen";
                        gpios = <&gpio 0xc 0x1>;
                        linux,code = <0x100>;
                        wakeup-source;
                        autorepeat;
                };
        };

        leds {
                compatible = "gpio-leds";

                ds35-led {
                        label = "heartbeat";
                        gpios = <&gpio 0x7 0x0>;
                        linux,default-trigger = "heartbeat";
                };

                ds36-led {
                        label = "vbus_det";
                        gpios = <&gpio 0x8 0x0>;
                        default-state = "on";
                };
        };

        pwm_fan: pwm-fan {
                phandle = <0x15b>;
                compatible = "pwm-fan";
                pwms = <&ttc0 0x2 0x9c40 0x1>;
        };

        __symbols__ {
                cpus_microblaze_0 = "/cpus_microblaze@0";
