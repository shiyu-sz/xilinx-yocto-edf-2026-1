        amba_xppu: indirect-bus@1 {
                phandle = <0x176>;
                compatible = "indirect-bus";
                #address-cells = <0x2>;
                #size-cells = <0x2>;

                lpd_xppu: xppu@ff990000 {
                        phandle = <0x7e>;
                        compatible = "xlnx,xppu";
                        #firewall-cells = <0x0>;
