                rpu0_shared_region = "/reserved-memory/rpu0_shared_region@10000000";
                rpu1_runtime_region = "/reserved-memory/rpu1_runtime_region@10800000";
                gic = "/axi/interrupt-controller@f9000000";
        };

        domains {

                APU_Linux {
                        compatible = "openamp,domain-v1";
                        reserved-memory = <0x17f 0x180 0x181>;
                        cpus = <&cpus_a72 0xf 0x80000003>;
                        os,type = "linux";

                        chosen {
                                stdout-path = "serial1:115200n8";
                                bootargs = "console=ttyAMA1 earlycon=pl011,mmio32,0xFF010000,115200n8";
                        };
                };
        };

        reserved-memory {
                #size-cells = <0x2>;
                #address-cells = <0x2>;
                ranges;

                rpu0_runtime_region: rpu0_runtime_region@0 {
                        phandle = <0x17f>;
                        label = "rpu0_runtime_region";
                        no-map;
                        reg = <0x0 0x0 0x0 0x10000000>;
                };

                rpu0_shared_region: rpu0_shared_region@10000000 {
                        phandle = <0x180>;
                        label = "rpu0_shared_region";
                        no-map;
                        reg = <0x0 0x10000000 0x0 0x800000>;
                };

                rpu1_runtime_region: rpu1_runtime_region@10800000 {
                        phandle = <0x181>;
                        label = "rpu1_runtime_region";
                        no-map;
                        reg = <0x0 0x10800000 0x0 0x4000000>;
                };
        };
};
