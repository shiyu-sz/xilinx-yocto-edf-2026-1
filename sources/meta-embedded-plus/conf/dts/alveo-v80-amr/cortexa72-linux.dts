        amba_xmpu: indirect-bus@2 {
                phandle = <0x160>;
                compatible = "indirect-bus";
                #address-cells = <0x2>;
                #size-cells = <0x2>;

                fpd_xmpu: xmpu@fd390000 {
                        phandle = <0x5e>;
                        compatible = "xlnx,xmpu";
                        #firewall-cells = <0x0>;
                        reg = <0x0 0xfd390000 0x0 0x1000>;
                        status = "okay";
                        xlnx,ip-name = "psv_fpd_slave_xmpu";
                };

                pmc_xmpu: xmpu@f12f0000 {
                        phandle = <0x53>;
                        compatible = "xlnx,xmpu";
                        #firewall-cells = <0x0>;
                        reg = <0x0 0xf12f0000 0x0 0x1000>;
                        status = "okay";
                        xlnx,ip-name = "psv_pmc_xmpu";
                };

                ocm_xmpu: xmpu@ff980000 {
                        phandle = <0x78>;
                        compatible = "xlnx,xmpu";
                        #firewall-cells = <0x0>;
                        reg = <0x0 0xff980000 0x0 0x1000>;
                        status = "okay";
                        xlnx,ip-name = "psv_ocm_xmpu";
                };

                ddrmc_xmpu_0: xmpu@f6080000 {
                        phandle = <0x161>;
                        compatible = "xlnx,xmpu";
                        #firewall-cells = <0x0>;
                        reg = <0x0 0xf6080000 0x0 0x1000>;
                        status = "disabled";
                };

                ddrmc_xmpu_1: xmpu@f6220000 {
                        phandle = <0x162>;
                        compatible = "xlnx,xmpu";
                        #firewall-cells = <0x0>;
                        reg = <0x0 0xf6220000 0x0 0x1000>;
                        status = "disabled";
                };

                ddrmc_xmpu_2: xmpu@f6390000 {
                        phandle = <0x163>;
                        compatible = "xlnx,xmpu";
                        #firewall-cells = <0x0>;
                        reg = <0x0 0xf6390000 0x0 0x1000>;
                        status = "disabled";
                };

                ddrmc_xmpu_3: xmpu@f6500000 {
                        phandle = <0x164>;
                        compatible = "xlnx,xmpu";
                        #firewall-cells = <0x0>;
                        reg = <0x0 0xf6500000 0x0 0x1000>;
                        status = "disabled";
                };

                fpd_funnel: fpd-funnel@f0b20000 {
                        phandle = <0x165>;
                        compatible = "arm,coresight-dynamic-funnel", "arm,primecell";
                        reg = <0x0 0xf0b20000 0x0 0x1000>;
                        clock-names = "apb_pclk";
                        status = "disabled";
                        clocks = <&versal_clk 0x52>;

                        in-ports {
                                #address-cells = <0x1>;
                                #size-cells = <0x0>;

                                port@1 {
                                        reg = <0x1>;

                                        fpd_funnel_in_port1: endpoint {
                                                phandle = <0xbc>;
                                                remote-endpoint = <&apu_etf_out_port>;
                                        };
                                };
                        };

                        out-ports {

                                port {

                                        fpd_funnel_out_port: endpoint {
                                                phandle = <0xb3>;
                                                remote-endpoint = <&fpd_etf_in_port>;
                                        };
                                };
                        };
                };

                fpd_etf: fpd-etf@f0b30000 {
                        phandle = <0x166>;
                        compatible = "arm,coresight-tmc", "arm,primecell";
                        reg = <0x0 0xf0b30000 0x0 0x1000>;
                        clock-names = "apb_pclk";
                        status = "disabled";
                        clocks = <&versal_clk 0x52>;

                        in-ports {

                                port {

                                        fpd_etf_in_port: endpoint {
                                                phandle = <0xb2>;
                                                remote-endpoint = <&fpd_funnel_out_port>;
                                        };
                                };
                        };

                        out-ports {

                                port {

                                        fpd_etf_out_port: endpoint {
                                                phandle = <0xb5>;
                                                remote-endpoint = <&replicator_in_port>;
                                        };
                                };
                        };
                };

                replicator: replicator@f0b40000 {
                        phandle = <0x167>;
                        compatible = "arm,coresight-dynamic-replicator", "arm,primecell";
                        reg = <0x0 0xf0b40000 0x0 0x1000>;
                        clock-names = "apb_pclk";
                        status = "disabled";
                        clocks = <&versal_clk 0x52>;

                        in-ports {

                                port {

                                        replicator_in_port: endpoint {
                                                phandle = <0xb4>;
                                                remote-endpoint = <&fpd_etf_out_port>;
                                        };
                                };
                        };

                        out-ports {
                                #address-cells = <0x1>;
                                #size-cells = <0x0>;

                                port@0 {
                                        reg = <0x0>;

                                        replicator_out_port0: endpoint {
                                                phandle = <0xb7>;
                                                remote-endpoint = <&etr_in_port>;
                                        };
                                };
                        };
                };

                etr: etr@f0b50000 {
                        phandle = <0x168>;
                        compatible = "arm,coresight-tmc", "arm,primecell";
                        reg = <0x0 0xf0b50000 0x0 0x1000>;
                        clock-names = "apb_pclk";
                        status = "disabled";
                        clocks = <&versal_clk 0x52>;

                        in-ports {

                                port {

                                        etr_in_port: endpoint {
                                                phandle = <0xb6>;
                                                remote-endpoint = <&replicator_out_port0>;
                                        };
                                };
                        };
                };

                apu_funnel: funnel@f0c20000 {
                        phandle = <0x169>;
                        compatible = "arm,coresight-dynamic-funnel", "arm,primecell";
                        reg = <0x0 0xf0c20000 0x0 0x1000>;
                        clock-names = "apb_pclk";
                        status = "disabled";
                        clocks = <&versal_clk 0x52>;

                        in-ports {
                                #address-cells = <0x1>;
                                #size-cells = <0x0>;

                                port@0 {
                                        reg = <0x0>;

                                        funnel_in_port0: endpoint {
                                                phandle = <0xbe>;
                                                remote-endpoint = <&etm0_out_port>;
                                        };
                                };

                                port@1 {
                                        reg = <0x1>;

                                        funnel_in_port1: endpoint {
                                                phandle = <0xc0>;
                                                remote-endpoint = <&etm1_out_port>;
                                        };
                                };
                        };

                        out-ports {

                                port {

                                        funnel_out_port: endpoint {
                                                phandle = <0xbb>;
                                                remote-endpoint = <&etf_in_port>;
                                        };
                                };
                        };
                };

                apu_etf: etf@f0c30000 {
                        phandle = <0x16a>;
                        compatible = "arm,coresight-tmc", "arm,primecell";
                        reg = <0x0 0xf0c30000 0x0 0x1000>;
                        clock-names = "apb_pclk";
                        status = "disabled";
                        clocks = <&versal_clk 0x52>;

                        in-ports {

                                port {

                                        etf_in_port: endpoint {
                                                phandle = <0xba>;
                                                remote-endpoint = <&funnel_out_port>;
                                        };
                                };
                        };

                        out-ports {

                                port {

                                        apu_etf_out_port: endpoint {
                                                phandle = <0xb1>;
                                                remote-endpoint = <&fpd_funnel_in_port1>;
                                        };
                                };
                        };
                };

                cpu0_debug: cpu0-debug@f0d00000 {
                        phandle = <0x16b>;
                        compatible = "arm,coresight-cpu-debug", "arm,primecell";
                        reg = <0x0 0xf0d00000 0x0 0x1000>;
                        clock-names = "apb_pclk";
                        cpu = <&psv_cortexa72_0>;
                        status = "disabled";
                        clocks = <&versal_clk 0x52>;
                };

                etm0: etm@f0d30000 {
                        phandle = <0x16c>;
                        compatible = "arm,coresight-etm4x", "arm,primecell";
                        reg = <0x0 0xf0d30000 0x0 0x1000>;
                        clock-names = "apb_pclk";
                        cpu = <&psv_cortexa72_0>;
                        status = "disabled";
                        clocks = <&versal_clk 0x52>;

                        out-ports {

                                port {

                                        etm0_out_port: endpoint {
                                                phandle = <0xb8>;
                                                remote-endpoint = <&funnel_in_port0>;
                                        };
                                };
                        };
                };

                cpu1_debug: cpu1-debug@f0d40000 {
                        phandle = <0x16d>;
                        compatible = "arm,coresight-cpu-debug", "arm,primecell";
                        reg = <0x0 0xf0d40000 0x0 0x1000>;
                        clock-names = "apb_pclk";
                        cpu = <&psv_cortexa72_1>;
                        status = "disabled";
                        clocks = <&versal_clk 0x52>;
                };

                etm1: etm@f0d70000 {
                        phandle = <0x16e>;
                        compatible = "arm,coresight-etm4x", "arm,primecell";
                        reg = <0x0 0xf0d70000 0x0 0x1000>;
                        clock-names = "apb_pclk";
                        cpu = <&psv_cortexa72_1>;
                        status = "disabled";
                        clocks = <&versal_clk 0x52>;

                        out-ports {

                                port {

                                        etm1_out_port: endpoint {
                                                phandle = <0xb9>;
                                                remote-endpoint = <&funnel_in_port1>;
                                        };
                                };
                        };
                };
        };

        pl_alt_ref: pl-alt-ref {
                phandle = <0xc2>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x1fca055>;
                clock-output-names = "pl_alt_ref_clk";
        };

        ref: ref {
                phandle = <0xc1>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x1fca055>;
                clock-output-names = "ref_clk";
        };

        rtc_clk: rtc-clk {
                phandle = <0xad>;
                bootph-all;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x8000>;
                clock-output-names = "rtc_clk";
        };

        can0_clk: can0-clk {
                phandle = <0xab>;
                #clock-cells = <0x0>;
                compatible = "fixed-factor-clock";
                clocks = <&versal_clk 0x60>;
                clock-div = <0x2>;
                clock-mult = <0x1>;
                clock-output-names = "can0_clk";
        };

        can1_clk: can1-clk {
                phandle = <0xac>;
                #clock-cells = <0x0>;
                compatible = "fixed-factor-clock";
                clocks = <&versal_clk 0x61>;
                clock-div = <0x2>;
                clock-mult = <0x1>;
                clock-output-names = "can1_clk";
        };

        firmware {

                versal_firmware: versal-firmware {
                        phandle = <0x8d>;
                        compatible = "xlnx,versal-firmware";
                        interrupt-parent = <&gic>;
                        bootph-all;
                        method = "smc";
                        #power-domain-cells = <0x1>;

                        versal_clk: clock-controller {
                                phandle = <0x8f>;
                                bootph-all;
                                #clock-cells = <0x1>;
                                compatible = "xlnx,versal-clk";
                                clocks = <&ref>,
                                 <&pl_alt_ref>;
                                clock-names = "ref", "pl_alt_ref";
                        };

                        zynqmp_power: power-management {
                                phandle = <0x16f>;
                                compatible = "xlnx,zynqmp-power";
                        };

                        versal_reset: reset-controller {
                                phandle = <0xae>;
                                compatible = "xlnx,versal-reset";
                                #reset-cells = <0x1>;
                        };

                        pinctrl0: pinctrl {
                                phandle = <0x170>;
                                compatible = "xlnx,versal-pinctrl";
                        };

                        versal_sec_cfg: versal-sec-cfg {
                                phandle = <0x171>;
                                compatible = "xlnx,versal-sec-cfg";

                                nvmem-layout {
                                        compatible = "fixed-layout";
                                        #address-cells = <0x1>;
                                        #size-cells = <0x1>;

                                        bbram_zeroize: bbram-zeroize@4 {
                                                phandle = <0x172>;
                                                reg = <0x4 0x4>;
                                        };

                                        bbram_key: bbram-key@10 {
                                                phandle = <0x173>;
                                                reg = <0x10 0x20>;
                                        };

                                        bbram_usr: bbram-usr@30 {
                                                phandle = <0x174>;
                                                reg = <0x30 0x4>;
                                        };

                                        bbram_lock: bbram-lock@48 {
                                                phandle = <0x175>;
                                                reg = <0x48 0x4>;
                                        };

                                        user_key0: user-key@110 {
                                                phandle = <0x176>;
                                                reg = <0x110 0x20>;
                                        };

                                        user_key1: user-key@130 {
                                                phandle = <0x177>;
                                                reg = <0x130 0x20>;
                                        };

                                        user_key2: user-key@150 {
                                                phandle = <0x178>;
                                                reg = <0x150 0x20>;
                                        };

                                        user_key3: user-key@170 {
                                                phandle = <0x179>;
                                                reg = <0x170 0x20>;
                                        };

                                        user_key4: user-key@190 {
                                                phandle = <0x17a>;
                                                reg = <0x190 0x20>;
                                        };

                                        user_key5: user-key@1b0 {
                                                phandle = <0x17b>;
                                                reg = <0x1b0 0x20>;
                                        };

                                        user_key6: user-key@1d0 {
                                                phandle = <0x17c>;
                                                reg = <0x1d0 0x20>;
                                        };

                                        user_key7: user-key@1f0 {
                                                phandle = <0x17d>;
                                                reg = <0x1f0 0x20>;
                                        };
                                };
                        };
                };
        };

        axi_noc_mc_ddr4_0_ddr_memory: memory@00000000 {
                phandle = <0x4>;
                compatible = "xlnx,axi-noc-1.1";
                xlnx,ip-name = "axi_noc";
                device_type = "memory";
                reg = <0x0 0x0 0x0 0x80000000>;
                memory_type = "memory";
        };

        chosen {
                stdout-path = "serial1:115200n8";
                bootargs = "console=ttyAMA1 earlycon=pl011,mmio32,0xFF010000,115200n8";
        };

        aliases {
                serial0 = "/axi/serial@ff000000";
                spi0 = "/axi/spi@f1010000";
                serial1 = "/axi/serial@ff010000";
                serial2 = "/axi/coresight@f0800000";
                i2c0 = "/axi/i2c@ff020000";
                i2c1 = "/axi/i2c@ff030000";
        };

        onewire {
                compatible = "w1-gpio";
                gpios = <&gpio0 0x4 0x0>;
        };

        __symbols__ {
                cpus_a72 = "/cpus-a72@0";
                psv_cortexa72_0 = "/cpus-a72@0/cpu@0";
                psv_cortexa72_1 = "/cpus-a72@0/cpu@1";
                CPU_SLEEP_0 = "/cpus-a72@0/idle-states/cpu-sleep-0";
                l2 = "/l2-cache";
                cpu_opp_table = "/opp-table-cpu";
                dcc = "/dcc";
                fpga = "/fpga-region";
                psci = "/psci";
                timer = "/timer";
                versal_fpga = "/versal-fpga";
                sensor0 = "/versal-thermal-sensor";
                versal_thermal = "/thermal-zones/versal-thermal";
                temp_alert = "/thermal-zones/versal-thermal/trips/temp-alert";
                ot_crit = "/thermal-zones/versal-thermal/trips/ot-crit";
                versal_thermal_aie = "/thermal-zones/versal-aie-thermal";
                temp_alert_aie = "/thermal-zones/versal-aie-thermal/trips/temp-alert-aie";
                ot_crit_aie = "/thermal-zones/versal-aie-thermal/trips/ot-crit-aie";
                amba_apu = "/apu-bus";
                gic_its = "/axi/interrupt-controller@f9000000/msi-controller@f9020000";
                amba = "/axi";
                imux = "/axi/interrupt-multiplex";
                can0 = "/axi/can@ff060000";
                can1 = "/axi/can@ff070000";
                cci = "/axi/cci@fd000000";
                cci_pmu = "/axi/cci@fd000000/pmu@10000";
                lpd_dma_chan0 = "/axi/dma-controller@ffa80000";
                lpd_dma_chan1 = "/axi/dma-controller@ffa90000";
                lpd_dma_chan2 = "/axi/dma-controller@ffaa0000";
                lpd_dma_chan3 = "/axi/dma-controller@ffab0000";
