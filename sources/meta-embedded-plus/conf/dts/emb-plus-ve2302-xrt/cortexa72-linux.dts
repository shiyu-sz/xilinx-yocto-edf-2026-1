        domains {

                APU_Linux {
                        compatible = "openamp,domain-v1";
                        reserved-memory = <0x1ad 0x1ae 0x1af 0x1b0 0x1b1 0x1b2>;
                        cpus = <&cpus_a72 0xf 0x80000003>;
                        os,type = "linux";

                        chosen {
                                bootargs = "console=ttyAMA1 earlycon=pl011,mmio32,0xFF010000,115200n8";
                                stdout-path = "serial0:115200n8";
                        };
                };
        };

        reserved-memory {
                #size-cells = <0x2>;
                #address-cells = <0x2>;
                ranges;

                u2a_xgq_region: buffer0@36000000 {
                        phandle = <0x1ad>;
                        label = "u2a_xgq_region";
                        no-map;
                        reg = <0x0 0x36000000 0x0 0x1000000>;
                };

                r2a_xgq_region: buffer@37000000 {
                        phandle = <0x1ae>;
                        label = "r2a_xgq_region";
                        no-map;
                        reg = <0x0 0x37000000 0x0 0x1000000>;
                };

                rpu_region_mgmt: buffer@38000000 {
                        phandle = <0x1af>;
                        label = "rpu_region_mgmt";
                        no-map;
                        reg = <0x0 0x38000000 0x0 0x8000000>;
                };

                rpu_region: buffer@40000000 {
                        phandle = <0x1b0>;
                        label = "rpu_region";
                        no-map;
                        reg = <0x0 0x40000000 0x0 0x20000000>;
                };

                cma_reserved: cma_reserved@50000000000 {
                        phandle = <0x1b1>;
                        label = "cma_reserved";
                        compatible = "shared-dma-pool";
                        reusable;
                        linux,cma-default;
                        reg = <0x500 0x0 0x0 0x40000000>;
                };

                zocl_versal_region0: buffer@50040000000 {
                        phandle = <0x1b2>;
                        label = "zocl_versal_region0";
                        no-map;
                        reg = <0x500 0x40000000 0x1 0x40000000>;
                };
        };

        fpga_PRulp: fpga-PRulp {
                phandle = <0x1a5>;
                ranges;
                compatible = "fpga-region";
                #address-cells = <0x2>;
                #size-cells = <0x2>;
        };

        misc_clk_0: misc_clk_0 {
                phandle = <0xd4>;
                compatible = "fixed-clock";
                clock-frequency = <0x7735940>;
                #clock-cells = <0x0>;
        };

        zyxclmm_drm@20200000000 {
                compatible = "xlnx,zocl-versal";
                status = "okay";
                memory-region = <&zocl_versal_region0>;
                reg = <0x202 0x0 0x0 0x100000>;
        };

        rpu-channel {
                compatible = "xlnx,rpu-channel";
                xlnx,xgq_buffer = <&r2a_xgq_region>;
                xlnx,xgq_device = <&blp_blp_logic_gcq_r2a>;
                interrupt-names = "irq_sq";
        };

        ert_hw {
                compatible = "xlnx,embedded_sched_versal";
                status = "okay";
                xlnx,xgq_buffer = <&u2a_xgq_region>;
                xlnx,xgq_device = <&blp_blp_logic_gcq_u2a_0>;
                interrupt-names = "irq_sq";

                cu_interrupt@0 {
                        interrupt-parent = <&blp_blp_logic_ert_support_axi_intc_0_31>;
                        interrupts = <0x0 0x4 0x1 0x4 0x2 0x4 0x3 0x4 0x4 0x4 0x5 0x4 0x6 0x4 0x7 0x4 0x8 0x4 0x9 0x4 0xa 0x4 0xb 0x4 0xc 0x4 0xd 0x4 0xe 0x4 0xf 0x4 0x10 0x4 0x11 0x4 0x12 0x4 0x13 0x4 0x14 0x4 0x15 0x4 0x16 0x4 0x17 0x4 0x18 0x4 0x19 0x4 0x1a 0x4 0x1b 0x4 0x1c 0x4 0x1d 0x4 0x1e 0x4 0x1f 0x4>;
                };
        };
};
