                u2a_xgq_region = "/reserved-memory/buffer0@36000000";
                r2a_xgq_region = "/reserved-memory/buffer@37000000";
                rpu_region_mgmt = "/reserved-memory/buffer@38000000";
                rpu_region = "/reserved-memory/buffer@40000000";
                cma_reserved = "/reserved-memory/cma_reserved@50000000000";
                zocl_versal_region0 = "/reserved-memory/buffer@50040000000";
                gic = "/axi/interrupt-controller@f9000000";
                aie_core_ref_clk = "/amba_pl/aie_core_ref_clk";
                fpga_PRulp = "/fpga-PRulp";
                misc_clk_0 = "/misc_clk_0";
