# Add softkernel user to run PS kernel Daemon.
if ! id -u softkernel >/dev/null 2>&1; then
    useradd softkernel
fi

# Work-around for AIE as it defaults root access only.
if [ -e /dev/aie0 ]; then
    chmod 666 /dev/aie0
fi

# Remove legacy xrt.ini from prior releases (shadows /etc on upgrade).
rm -f /usr/bin/xrt.ini

# Create default xrt.ini if not already present.
if [ ! -e /etc/xrt.ini ]; then
    echo "# xrt.ini generated by init-apu script" > /etc/xrt.ini
    echo "[Runtime]" >> /etc/xrt.ini
    echo "verbosity=5" >> /etc/xrt.ini
    echo "runtime_log=syslog" >> /etc/xrt.ini
    echo "enable_aied=false" >> /etc/xrt.ini
fi

