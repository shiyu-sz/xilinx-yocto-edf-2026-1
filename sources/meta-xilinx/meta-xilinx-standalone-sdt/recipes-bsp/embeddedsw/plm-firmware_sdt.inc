inherit esw

DEPENDS += "\
    xilstandalone \
    xiltimer \
    xilffs \
    xilpdi \
    xilplmi \
    xilloader \
    ${@'xilpm-ng' if d.getVar('ESW_MACHINE') == 'pmc_0' else 'xilpm'} \
    xilsecure \
    xilsem \
    xilnvm \
    xiltpm \
    xilocp \
    xilcert \
    "

TARGET_LDFLAGS:append:pmc_0 = " -T${RECIPE_SYSROOT}${libdir}/xpm_memory_pools.ld"

ESW_COMPONENT_SRC = "/lib/sw_apps/versal_plm/src/"

do_configure:prepend() {
    (
    cd ${S}
    install -m 0644 ${S}/cmake/UserConfig.cmake ${S}/${ESW_COMPONENT_SRC}
    )
}

do_install() {
    :
}

ESW_COMPONENT = "versal_plm.elf"

do_deploy() {
    install -Dm 0644 ${B}/${ESW_COMPONENT} ${DEPLOYDIR}/${PLM_BASE_NAME}.elf
    ln -sf ${PLM_BASE_NAME}.elf ${DEPLOYDIR}/${PLM_IMAGE_NAME}.elf
}

addtask deploy before do_build after do_install
