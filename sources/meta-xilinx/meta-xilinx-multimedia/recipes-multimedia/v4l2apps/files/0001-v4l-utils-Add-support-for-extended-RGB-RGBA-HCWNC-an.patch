From b05ed82b7a861f5529f92e62e3dae2af8b8cd481 Mon Sep 17 00:00:00 2001
From: Mounik Katikala <mounik.katikala@amd.com>
Date: Wed, 13 May 2026 14:01:59 +0530
Subject: [PATCH] v4l-utils: Add support for extended RGB/RGBA, HCWNC, and grey
 formats

Add support for matching media bus codes, V4L2 pixel formats, and
media-ctl libv4l2subdev name-to-mbus mappings for BF16/FP16/FP32 RGB and
RGBA (packed and planar, including 4x3-tiled planar), HCWNC4/HCWNC8 NPU
layouts, and GREY_BF16 / GREY_FP16 / GREY_FP32.

Upstream-Status: Pending

Signed-off-by: Mounik Katikala <mounik.katikala@amd.com>
---
 include/linux/media-bus-format.h | 20 +++++++++++--
 include/linux/videodev2.h        | 51 ++++++++++++++++++++++++++++++++
 utils/media-ctl/libv4l2subdev.c  | 45 ++++++++++++++++++++++++++++
 3 files changed, 114 insertions(+), 2 deletions(-)

diff --git a/include/linux/media-bus-format.h b/include/linux/media-bus-format.h
index 45f6707d..d9041e57 100644
--- a/include/linux/media-bus-format.h
+++ b/include/linux/media-bus-format.h
@@ -34,7 +34,10 @@

 #define MEDIA_BUS_FMT_FIXED			0x0001

-/* RGB - next is	0x1026 */
+/* RGB - next is	0x1035
+ * Note: 0x101b-0x102d are intentionally left unused to match media-bus-format
+ *  numbering of linux-xlnx.
+ */
 #define MEDIA_BUS_FMT_RGB444_1X12		0x1016
 #define MEDIA_BUS_FMT_RGB444_2X8_PADHI_BE	0x1001
 #define MEDIA_BUS_FMT_RGB444_2X8_PADHI_LE	0x1002
@@ -73,7 +76,16 @@
 #define MEDIA_BUS_FMT_RGB121212_1X36		0x1019
 #define MEDIA_BUS_FMT_RGB161616_1X48		0x101a

-/* YUV (including grey) - next is	0x202f */
+#define MEDIA_BUS_FMT_RGB_BF161616_1X48		0x102e
+#define MEDIA_BUS_FMT_RGB_FP161616_1X48		0x102f
+#define MEDIA_BUS_FMT_RGB_FP323232_1X96		0x1030
+
+#define MEDIA_BUS_FMT_RGBA8888_1X32		0x1031
+#define MEDIA_BUS_FMT_RGBA_BF16161616_1X64	0x1032
+#define MEDIA_BUS_FMT_RGBA_FP16161616_1X64	0x1033
+#define MEDIA_BUS_FMT_RGBA_FP32323232_1X128	0x1034
+
+/* YUV (including grey) - next is	0x2032 */
 #define MEDIA_BUS_FMT_Y8_1X8			0x2001
 #define MEDIA_BUS_FMT_UV8_1X8			0x2015
 #define MEDIA_BUS_FMT_UYVY8_1_5X8		0x2002
@@ -121,6 +133,10 @@
 #define MEDIA_BUS_FMT_YUV16_1X48		0x202a
 #define MEDIA_BUS_FMT_UYYVYY16_0_5X48		0x202b

+#define MEDIA_BUS_FMT_Y_BF16_1X16		0x202f
+#define MEDIA_BUS_FMT_Y_FP16_1X16		0x2030
+#define MEDIA_BUS_FMT_Y_FP32_1X32		0x2031
+
 /* YUV: Xilinx Specific - next is       0x2108 */
 #define MEDIA_BUS_FMT_VYYUYY8_1X24		0x2100
 #define MEDIA_BUS_FMT_VYYUYY10_4X20		0x2101
diff --git a/include/linux/videodev2.h b/include/linux/videodev2.h
index 397a99e3..7356daa4 100644
--- a/include/linux/videodev2.h
+++ b/include/linux/videodev2.h
@@ -556,6 +556,54 @@ struct v4l2_pix_format {
 /* RGB formats (6 or 8 bytes per pixel) */
 #define V4L2_PIX_FMT_BGR48_12    v4l2_fourcc('B', '3', '1', '2') /* 48  BGR 12-bit per component */
 #define V4L2_PIX_FMT_ABGR64_12   v4l2_fourcc('B', '4', '1', '2') /* 64  BGRA 12-bit per component */
+#define V4L2_PIX_FMT_RGB_BF48  v4l2_fourcc('B', 'B', '4', '8') /* 48  RGB-BF-16-16-16 */
+#define V4L2_PIX_FMT_RGB_FP48  v4l2_fourcc('B', 'F', '4', '8') /* 48  RGB-FP-16-16-16 */
+#define V4L2_PIX_FMT_RGB_FP323232  v4l2_fourcc('B', 'R', '9', '6') /* 96  RGB-32-32-32 */
+#define V4L2_PIX_FMT_RGBA_BF64  v4l2_fourcc('B', 'B', '6', '4') /* 64  RGBA-BF-16-16-16-16 */
+#define V4L2_PIX_FMT_RGBA_FP64  v4l2_fourcc('B', 'F', '6', '4') /* 64  RGBA-FP-16-16-16-16 */
+#define V4L2_PIX_FMT_RGBA_FP32323232  v4l2_fourcc('B', 'A', '3', '2') /* 128  RGBA-FP-32-32-32-32 */
+#define V4L2_PIX_FMT_RGB24P  v4l2_fourcc('B', 'R', 'M', '3') /* 24  RGB-8-8-8 planar */
+#define V4L2_PIX_FMT_RGB_BF48P  v4l2_fourcc('B', 'B', '4', 'M') /* 48  RGB-BF-16-16-16 planar */
+#define V4L2_PIX_FMT_RGB_FP48P  v4l2_fourcc('B', 'F', '4', 'M') /* 48  RGB-FP-16-16-16 planar */
+#define V4L2_PIX_FMT_RGB_FP323232P  v4l2_fourcc('B', '9', '6', 'M') /* 96  RGB-FP-32-32-32 planar */
+#define V4L2_PIX_FMT_RGBA32P  v4l2_fourcc('B', 'A', '8', 'M') /* 32  RGBA-8-8-8-8 planar */
+#define V4L2_PIX_FMT_RGBA_BF64P  v4l2_fourcc('B', 'B', '6', 'M') /* 64  RGBA-BF-16-16-16-16 planar */
+#define V4L2_PIX_FMT_RGBA_FP64P  v4l2_fourcc('B', 'F', '6', 'M') /* 64  RGBA-FP-16-16-16-16 planar */
+#define V4L2_PIX_FMT_RGBA_FP32323232P  v4l2_fourcc('B', '3', '2', 'M') /* 128  RGBA-FP-32-32-32-32 planar */
+#define V4L2_PIX_FMT_RGB24P_4_3  v4l2_fourcc('B', '3', '4', '3') /* 24  RGB-8-8-8 planar 4x3 */
+#define V4L2_PIX_FMT_RGB_BF48P_4_3  v4l2_fourcc('B', '4', '4', '3') /* 48  RGB-BF-16-16-16 planar 4x3 */
+#define V4L2_PIX_FMT_RGB_FP48P_4_3  v4l2_fourcc('B', '5', '4', '3') /* 48  RGB-FP-16-16-16 planar 4x3 */
+#define V4L2_PIX_FMT_RGB_FP323232P_4_3  v4l2_fourcc('B', '6', '4', '3') /* 96  RGB-FP-32-32-32 planar 4x3 */
+
+/*
+ * HCWNC packed formats (NPU channel-blocked memory layouts).
+ * HCWNC4 / HCWNC8 expand to Height-Channel-Width-Batch-Channel4 and
+ * Height-Channel-Width-Batch-Channel8;
+ */
+#define V4L2_PIX_FMT_HCWNC4_8_4_4		v4l2_fourcc('H', 'C', '4', '8')  /* 32  HCWNC4 u8 4x4 */
+#define V4L2_PIX_FMT_HCWNC4_BF16_4_4		v4l2_fourcc('H', 'B', '4', '6')  /* 64  HCWNC4 BF16 4x4 */
+#define V4L2_PIX_FMT_HCWNC4_FP16_4_4		v4l2_fourcc('H', 'F', '4', '6')  /* 64  HCWNC4 FP16 4x4 */
+#define V4L2_PIX_FMT_HCWNC4_FP32_4_4		v4l2_fourcc('H', '4', '3', '2')  /* 128 HCWNC4 FP32 4x4 */
+#define V4L2_PIX_FMT_HCWNC8_8_4_4		v4l2_fourcc('H', 'C', '8', '8')  /* 64  HCWNC8 u8 4x4 */
+#define V4L2_PIX_FMT_HCWNC8_BF16_4_4		v4l2_fourcc('H', 'B', '8', '6')  /* 128 HCWNC8 BF16 4x4 */
+#define V4L2_PIX_FMT_HCWNC8_FP16_4_4		v4l2_fourcc('H', 'F', '8', '6')  /* 128 HCWNC8 FP16 4x4 */
+#define V4L2_PIX_FMT_HCWNC8_FP32_4_4		v4l2_fourcc('H', '8', '3', '2')  /* 256 HCWNC8 FP32 4x4 */
+#define V4L2_PIX_FMT_HCWNC4_8_4_3		v4l2_fourcc('H', 'C', '4', '3')  /* 32  HCWNC4 u8 4x3 */
+#define V4L2_PIX_FMT_HCWNC4_BF16_4_3		v4l2_fourcc('H', 'B', '4', '3')  /* 64  HCWNC4 BF16 4x3 */
+#define V4L2_PIX_FMT_HCWNC4_FP16_4_3		v4l2_fourcc('H', 'F', '4', '3')  /* 64  HCWNC4 FP16 4x3 */
+#define V4L2_PIX_FMT_HCWNC4_FP32_4_3		v4l2_fourcc('H', '4', '3', '3')  /* 128 HCWNC4 FP32 4x3 */
+#define V4L2_PIX_FMT_HCWNC8_8_4_3		v4l2_fourcc('H', 'C', '8', '3')  /* 64  HCWNC8 u8 4x3 */
+#define V4L2_PIX_FMT_HCWNC8_BF16_4_3		v4l2_fourcc('H', 'B', '8', '3')  /* 128 HCWNC8 BF16 4x3 */
+#define V4L2_PIX_FMT_HCWNC8_FP16_4_3		v4l2_fourcc('H', 'F', '8', '3')  /* 128 HCWNC8 FP16 4x3 */
+#define V4L2_PIX_FMT_HCWNC8_FP32_4_3		v4l2_fourcc('H', '8', '3', '3')  /* 256 HCWNC8 FP32 4x3 */
+#define V4L2_PIX_FMT_HCWNC4_8_3_3		v4l2_fourcc('H', 'C', '4', '4')  /* 32  HCWNC4 u8 3x3 */
+#define V4L2_PIX_FMT_HCWNC4_BF16_3_3		v4l2_fourcc('H', 'B', '4', '4')  /* 64  HCWNC4 BF16 3x3 */
+#define V4L2_PIX_FMT_HCWNC4_FP16_3_3		v4l2_fourcc('H', 'F', '4', '4')  /* 64  HCWNC4 FP16 3x3 */
+#define V4L2_PIX_FMT_HCWNC4_FP32_3_3		v4l2_fourcc('H', '4', '3', '4')  /* 128 HCWNC4 FP32 3x3 */
+#define V4L2_PIX_FMT_HCWNC8_8_3_3		v4l2_fourcc('H', 'C', '8', '4')  /* 64  HCWNC8 u8 3x3 */
+#define V4L2_PIX_FMT_HCWNC8_BF16_3_3		v4l2_fourcc('H', 'B', '8', '4')  /* 128 HCWNC8 BF16 3x3 */
+#define V4L2_PIX_FMT_HCWNC8_FP16_3_3		v4l2_fourcc('H', 'F', '8', '4')  /* 128 HCWNC8 FP16 3x3 */
+#define V4L2_PIX_FMT_HCWNC8_FP32_3_3		v4l2_fourcc('H', '8', '3', '4')  /* 256 HCWNC8 FP32 3x3 */

 /* Grey formats */
 #define V4L2_PIX_FMT_GREY    v4l2_fourcc('G', 'R', 'E', 'Y') /*  8  Greyscale     */
@@ -567,6 +615,9 @@ struct v4l2_pix_format {
 #define V4L2_PIX_FMT_Y14     v4l2_fourcc('Y', '1', '4', ' ') /* 14  Greyscale     */
 #define V4L2_PIX_FMT_Y16     v4l2_fourcc('Y', '1', '6', ' ') /* 16  Greyscale     */
 #define V4L2_PIX_FMT_Y16_BE  v4l2_fourcc_be('Y', '1', '6', ' ') /* 16  Greyscale BE  */
+#define V4L2_PIX_FMT_GREY_BF16     v4l2_fourcc('Y', 'B', '1', '6') /* 16 BF16 Greyscale     */
+#define V4L2_PIX_FMT_GREY_FP16     v4l2_fourcc('Y', 'F', '1', '6') /* 16 FP16 Greyscale     */
+#define V4L2_PIX_FMT_GREY_FP32     v4l2_fourcc('Y', 'F', '3', '2') /* 32 FP32 Greyscale     */

 /* Grey bit-packed formats */
 #define V4L2_PIX_FMT_Y10BPACK    v4l2_fourcc('Y', '1', '0', 'B') /* 10  Greyscale bit-packed */
diff --git a/utils/media-ctl/libv4l2subdev.c b/utils/media-ctl/libv4l2subdev.c
index c614f4a2..4b0156a9 100644
--- a/utils/media-ctl/libv4l2subdev.c
+++ b/utils/media-ctl/libv4l2subdev.c
@@ -1173,6 +1173,51 @@ static const struct {
 	{ "RBG24", MEDIA_BUS_FMT_RBG888_1X24 },
 	{ "RGB32", MEDIA_BUS_FMT_RGB888_1X32_PADHI },
 	{ "ARGB32", MEDIA_BUS_FMT_ARGB8888_1X32 },
+	{ "RGB_BF48", MEDIA_BUS_FMT_RGB_BF161616_1X48 },
+	{ "RGB_FP48", MEDIA_BUS_FMT_RGB_FP161616_1X48 },
+	{ "RGB_FP323232", MEDIA_BUS_FMT_RGB_FP323232_1X96 },
+	{ "RGBA_BF64", MEDIA_BUS_FMT_RGBA_BF16161616_1X64 },
+	{ "RGBA_FP64", MEDIA_BUS_FMT_RGBA_FP16161616_1X64 },
+	{ "RGBA_FP32323232", MEDIA_BUS_FMT_RGBA_FP32323232_1X128 },
+	{ "RGB24P", MEDIA_BUS_FMT_RBG888_1X24 },
+	{ "RGB_BF48P", MEDIA_BUS_FMT_RGB_BF161616_1X48 },
+	{ "RGB_FP48P", MEDIA_BUS_FMT_RGB_FP161616_1X48 },
+	{ "RGB_FP323232P", MEDIA_BUS_FMT_RGB_FP323232_1X96 },
+	{ "RGBA32P", MEDIA_BUS_FMT_RGBA8888_1X32 },
+	{ "RGBA_BF64P", MEDIA_BUS_FMT_RGBA_BF16161616_1X64 },
+	{ "RGBA_FP64P", MEDIA_BUS_FMT_RGBA_FP16161616_1X64 },
+	{ "RGBA_FP32323232P", MEDIA_BUS_FMT_RGBA_FP32323232_1X128 },
+	{ "RGB24P_4_3", MEDIA_BUS_FMT_RGBA8888_1X32 },
+	{ "RGB_BF48P_4_3", MEDIA_BUS_FMT_RGBA_BF16161616_1X64 },
+	{ "RGB_FP48P_4_3", MEDIA_BUS_FMT_RGBA_FP16161616_1X64 },
+	{ "RGB_FP323232P_4_3", MEDIA_BUS_FMT_RGBA_FP32323232_1X128 },
+	{ "HCWNC4_8_4_4", MEDIA_BUS_FMT_RGBA8888_1X32 },
+	{ "HCWNC4_BF16_4_4", MEDIA_BUS_FMT_RGBA_BF16161616_1X64 },
+	{ "HCWNC4_FP16_4_4", MEDIA_BUS_FMT_RGBA_FP16161616_1X64 },
+	{ "HCWNC4_FP32_4_4", MEDIA_BUS_FMT_RGBA_FP32323232_1X128 },
+	{ "HCWNC8_8_4_4", MEDIA_BUS_FMT_RGBA8888_1X32 },
+	{ "HCWNC8_BF16_4_4", MEDIA_BUS_FMT_RGBA_BF16161616_1X64 },
+	{ "HCWNC8_FP16_4_4", MEDIA_BUS_FMT_RGBA_FP16161616_1X64 },
+	{ "HCWNC8_FP32_4_4", MEDIA_BUS_FMT_RGBA_FP32323232_1X128 },
+	{ "HCWNC4_8_4_3", MEDIA_BUS_FMT_RBG888_1X24 },
+	{ "HCWNC4_BF16_4_3", MEDIA_BUS_FMT_RGBA_BF16161616_1X64 },
+	{ "HCWNC4_FP16_4_3", MEDIA_BUS_FMT_RGBA_FP16161616_1X64 },
+	{ "HCWNC4_FP32_4_3", MEDIA_BUS_FMT_RGBA_FP32323232_1X128 },
+	{ "HCWNC8_8_4_3", MEDIA_BUS_FMT_RGBA8888_1X32 },
+	{ "HCWNC8_BF16_4_3", MEDIA_BUS_FMT_RGBA_BF16161616_1X64 },
+	{ "HCWNC8_FP16_4_3", MEDIA_BUS_FMT_RGBA_FP16161616_1X64 },
+	{ "HCWNC8_FP32_4_3", MEDIA_BUS_FMT_RGBA_FP32323232_1X128 },
+	{ "HCWNC4_8_3_3", MEDIA_BUS_FMT_RBG888_1X24 },
+	{ "HCWNC4_BF16_3_3", MEDIA_BUS_FMT_RGB_BF161616_1X48 },
+	{ "HCWNC4_FP16_3_3", MEDIA_BUS_FMT_RGB_FP161616_1X48 },
+	{ "HCWNC4_FP32_3_3", MEDIA_BUS_FMT_RGB_FP323232_1X96 },
+	{ "HCWNC8_8_3_3", MEDIA_BUS_FMT_RBG888_1X24 },
+	{ "HCWNC8_BF16_3_3", MEDIA_BUS_FMT_RGB_BF161616_1X48 },
+	{ "HCWNC8_FP16_3_3", MEDIA_BUS_FMT_RGB_FP161616_1X48 },
+	{ "HCWNC8_FP32_3_3", MEDIA_BUS_FMT_RGB_FP323232_1X96 },
+	{ "GREY_BF16", MEDIA_BUS_FMT_Y_BF16_1X16 },
+	{ "GREY_FP16", MEDIA_BUS_FMT_Y_FP16_1X16 },
+	{ "GREY_FP32", MEDIA_BUS_FMT_Y_FP32_1X32 },
 };

 const char *v4l2_subdev_pixelcode_to_string(enum v4l2_mbus_pixelcode code)
--
2.43.0

