@@ -289,6 +289,46 @@ static void fill_smpte_yuv_planar(const struct util_yuv_info *yuv,
 	}
 }
 
+/*
+ * Helper function to determine SMPTE color index based on pixel position
+ *
+ * SMPTE color bar pattern has 3 vertical sections:
+ *   - Top section (0-6/9 height): 7 vertical color bars
+ *   - Middle section (6/9-7/9 height): 7 vertical bars with alternating pattern
+ *   - Bottom section (7/9-9/9 height): Complex pattern with 3 horizontal regions
+ *     * Left region (0-5/7 width): 4 colors
+ *     * Middle region (5/7-6/7 width): 3 colors
+ *     * Right region (6/7-7/7 width): 1 color
+ */
+static inline unsigned int get_smpte_color_index(unsigned int x, unsigned int y,
+						 unsigned int width, unsigned int height)
+{
+	/* Determine which vertical section this pixel belongs to */
+	if (y < height * 6 / 9) {
+		/* Top section: 7 equal vertical bars (colors 0-6) */
+		return (x * 7) / width;
+	} else if (y < height * 7 / 9) {
+		/* Middle section: 7 equal vertical bars (colors 7-13) */
+		return 7 + (x * 7) / width;
+	} else {
+		/* Bottom section: Complex 3-region pattern (colors 14-21) */
+		unsigned int width_5_7 = width * 5 / 7;
+		unsigned int width_6_7 = width * 6 / 7;
+
+		if (x < width_5_7) {
+			/* Left region: 4 colors (indices 14-17) */
+			return 14 + (x * 4) / width_5_7;
+		} else if (x < width_6_7) {
+			/* Middle region: 3 colors (indices 18-20) */
+			unsigned int width_1_7 = width / 7;
+			return 18 + ((x - width_5_7) * 3) / width_1_7;
+		} else {
+			/* Right region: Single color (index 21) */
+			return 21;
+		}
+	}
+}
+
 static void write_pixels_10bpp(unsigned char *mem,
 			       unsigned short a,
 			       unsigned short b,
@@ -302,6 +342,545 @@ static void write_pixels_10bpp(unsigned char *mem,
 	  mem[4] = ((d >> 2) & 0xff);
 }
 
+static void write_pixels_12bpp(unsigned char *mem,
+			       unsigned short a,
+			       unsigned short b)
+{
+	  mem[0] = (a & 0xff);
+	  mem[1] = ((a >> 8) & 0xf) | ((b & 0xf) << 4);
+	  mem[2] = ((b >> 4) & 0xff);
+}
+
+/*
+ * SMPTE tiled format generator for 8/10/12-bit YUV formats
+ *
+ * This function generates SMPTE color bars directly in tiled format.
+ * Tiled format organizes pixels into 32x4/64x4 blocks, with multiple blocks per frame.
+ *
+ * Tile structure:
+ *   - Each tile is 32/64 pixels wide (determined by format)
+ *   - Each tile is having 4 pixels height
+ *   - Each tile contains pixel data stored in packed format (8/10/12 bits per channel)
+ *   - Tiles are arranged row by row
+ *
+ * Supports YUV444 (4:4:4), YUV422 (4:2:2), and YUV420 (4:2:0) formats
+ */
+static void fill_smpte_tiled_yuv(const struct util_yuv_info *yuv,
+				  unsigned char *y_mem, unsigned char *u_mem,
+				  unsigned char *v_mem, unsigned int width,
+				  unsigned int height, unsigned int stride,
+				  uint32_t format)
+{
+	/* SMPTE color bar colors in YUV format */
+	static const struct color_yuv colors_all[] = {
+		/* Top section: 7 color bars (white, yellow, cyan, green, magenta, red, blue) */
+		MAKE_YUV_601(192, 192, 192),  /* 0: White */
+		MAKE_YUV_601(192, 192, 0),    /* 1: Yellow */
+		MAKE_YUV_601(0, 192, 192),    /* 2: Cyan */
+		MAKE_YUV_601(0, 192, 0),      /* 3: Green */
+		MAKE_YUV_601(192, 0, 192),    /* 4: Magenta */
+		MAKE_YUV_601(192, 0, 0),      /* 5: Red */
+		MAKE_YUV_601(0, 0, 192),      /* 6: Blue */
+		/* Middle section: 7 bars with alternating pattern */
+		MAKE_YUV_601(0, 0, 192),      /* 7: Blue */
+		MAKE_YUV_601(19, 19, 19),     /* 8: Black */
+		MAKE_YUV_601(192, 0, 192),    /* 9: Magenta */
+		MAKE_YUV_601(19, 19, 19),     /* 10: Black */
+		MAKE_YUV_601(0, 192, 192),    /* 11: Cyan */
+		MAKE_YUV_601(19, 19, 19),     /* 12: Black */
+		MAKE_YUV_601(192, 192, 192),  /* 13: White */
+		/* Bottom section: Test signal colors */
+		MAKE_YUV_601(0, 33, 76),      /* 14: I signal */
+		MAKE_YUV_601(255, 255, 255),  /* 15: White */
+		MAKE_YUV_601(50, 0, 106),     /* 16: Q signal */
+		MAKE_YUV_601(19, 19, 19),     /* 17: Black */
+		MAKE_YUV_601(9, 9, 9),        /* 18: -4 IRE */
+		MAKE_YUV_601(19, 19, 19),     /* 19: 0 IRE (Black) */
+		MAKE_YUV_601(29, 29, 29),     /* 20: +4 IRE */
+		MAKE_YUV_601(19, 19, 19),     /* 21: 0 IRE (Black) */
+	};
+
+	/* Get chroma subsampling factors (1 for 444, 2 for horizontal/vertical subsampling) */
+	const unsigned int xsub = yuv->xsub;  /* Horizontal chroma subsampling */
+	const unsigned int ysub = yuv->ysub;  /* Vertical chroma subsampling */
+
+	/* Bit depth configuration default to 8-bit */
+	unsigned char bitdepth = 8;
+
+	/* Will be set to 10, or 12 based on format */
+	if (((format >> 24) & 0xFF) == 'A') {
+		bitdepth = 10;
+	} else if (((format >> 24) & 0xFF) == 'C') {
+		bitdepth = 12;
+	}
+
+	/* Calculate bytes per 4 pixels based on bit depth (packed formats) */
+	/* 8-bit: 4 pixels = 4 bytes, 10-bit: 4 pixels = 5 bytes, 12-bit: 4 pixels = 6 bytes */
+	unsigned int bytes_per_4px = (bitdepth == 8) ? 4 : (bitdepth == 10) ? 5 : 6;
+
+	/* Tile configuration */
+	const unsigned int tile_width = ((format >> 8) & 0xFF) == '5' ? 32 : 64;	/* Width of each tile in pixels */
+	const unsigned int blocks_per_tile = tile_width / 4;     /* Number of 4x4 blocks per tile */
+
+	/* Calculate tile dimensions */
+	const unsigned int num_tiles_h_y = height / 4;           /* Number of 4-pixel-high tile rows for Y */
+	const unsigned int num_tiles_h_c = (height / ysub) / 4;  /* Number of tile rows for chroma */
+	const unsigned int full_tiles_w = width / tile_width;    /* Number of complete tiles per row */
+	const unsigned int partial_blocks = (width % tile_width) / 4;  /* Remaining partial blocks */
+
+	/* ===================================================================
+	 * STEP 1: Generate Y (Luma) plane in tiled format
+	 * Each Y tile row represents 4 pixel rows
+	 * =================================================================== */
+	for (unsigned int tile_row = 0; tile_row < num_tiles_h_y; tile_row++) {
+		/* Calculate the starting Y coordinate for this tile row */
+		const unsigned int base_y = tile_row * 4;
+
+		/* Get pointer to the start of this tile row in memory */
+		unsigned char *y_tile = y_mem + (size_t)tile_row * stride * 4;
+
+		/* Process each complete tile in this row */
+		for (unsigned int tile_col = 0; tile_col < full_tiles_w; tile_col++) {
+			/* Calculate the starting X coordinate for this tile */
+			const unsigned int base_x = tile_col * tile_width;
+
+			/* Get pointer to this tile (bytes depend on bit depth packing) */
+			unsigned char *y_block = y_tile + (size_t)tile_col * (tile_width / 4) * 4 * bytes_per_4px;
+
+			/* Process each 4x4 block within the tile */
+			for (unsigned int block = 0; block < blocks_per_tile; block++) {
+				/* Calculate X coordinate for this block (blocks are 4 pixels wide) */
+				const unsigned int block_x = base_x + block * 4;
+
+				/* Fill the 4x4 block with Y values */
+				for (unsigned int row = 0; row < 4; row++) {
+					const unsigned int pixel_y = base_y + row;
+
+					/* Collect 4 pixel values for packed writing */
+					unsigned int color_idx[4];
+					for (unsigned int col = 0; col < 4; col++) {
+						const unsigned int pixel_x = block_x + col;
+						color_idx[col] = get_smpte_color_index(pixel_x, pixel_y, width, height);
+					}
+
+					/* Write 4 pixels based on bit depth */
+					if (bitdepth == 8) {
+						y_block[0] = colors_all[color_idx[0]].y;
+						y_block[1] = colors_all[color_idx[1]].y;
+						y_block[2] = colors_all[color_idx[2]].y;
+						y_block[3] = colors_all[color_idx[3]].y;
+						y_block += 4;
+					} else if (bitdepth == 10) {
+						write_pixels_10bpp(y_block,
+							(colors_all[color_idx[0]].y << 2),
+							(colors_all[color_idx[1]].y << 2),
+							(colors_all[color_idx[2]].y << 2),
+							(colors_all[color_idx[3]].y << 2));
+						y_block += 5;
+					} else {  /* 12-bit */
+						write_pixels_12bpp(y_block,
+							(colors_all[color_idx[0]].y << 4),
+							(colors_all[color_idx[1]].y << 4));
+						write_pixels_12bpp(y_block + 3,
+							(colors_all[color_idx[2]].y << 4),
+							(colors_all[color_idx[3]].y << 4));
+						y_block += 6;
+					}
+				}
+			}
+		}
+
+		/* Handle partial blocks at the end of the row (if width not divisible by tile_width) */
