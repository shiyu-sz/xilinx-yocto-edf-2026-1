+static inline void write_cc_xx_bpc_16(unsigned char *mem,
+				      unsigned char bpc,
+				      bool msb,
+				      unsigned char cc)
+{
+	assert(bpc >= 8 && bpc <= 16);
+	unsigned short mask = msb ? ~(1 << (16 - bpc) - 1) : (1 << bpc) - 1;
+	unsigned short shift = msb ? 8 : bpc - 8;
+	unsigned short *dst = (unsigned short *)mem;
+
+	*dst = ((unsigned short)cc << shift) & mask;
+}
+
+static void fill_smpte_yuv_planar_xx_bpc_16(const struct util_yuv_info *yuv,
+					    unsigned char *y_mem,
+					    unsigned char *u_mem,
+					    unsigned char *v_mem,
+					    unsigned int width,
+					    unsigned int height,
+					    unsigned int stride,
+					    unsigned char bpc,
+					    bool msb)
+{
+	const struct color_yuv colors_top[] = {
+		MAKE_YUV_601(192, 192, 192),	/* grey */
+		MAKE_YUV_601(192, 192, 0),	/* yellow */
+		MAKE_YUV_601(0, 192, 192),	/* cyan */
+		MAKE_YUV_601(0, 192, 0),	/* green */
+		MAKE_YUV_601(192, 0, 192),	/* magenta */
+		MAKE_YUV_601(192, 0, 0),	/* red */
+		MAKE_YUV_601(0, 0, 192),	/* blue */
+	};
+	const struct color_yuv colors_middle[] = {
+		MAKE_YUV_601(0, 0, 192),	/* blue */
+		MAKE_YUV_601(19, 19, 19),	/* black */
+		MAKE_YUV_601(192, 0, 192),	/* magenta */
+		MAKE_YUV_601(19, 19, 19),	/* black */
+		MAKE_YUV_601(0, 192, 192),	/* cyan */
+		MAKE_YUV_601(19, 19, 19),	/* black */
+		MAKE_YUV_601(192, 192, 192),	/* grey */
+	};
+	const struct color_yuv colors_bottom[] = {
+		MAKE_YUV_601(0, 33, 76),	/* in-phase */
+		MAKE_YUV_601(255, 255, 255),	/* super white */
+		MAKE_YUV_601(50, 0, 106),	/* quadrature */
+		MAKE_YUV_601(19, 19, 19),	/* black */
+		MAKE_YUV_601(9, 9, 9),		/* 3.5% */
+		MAKE_YUV_601(19, 19, 19),	/* 7.5% */
+		MAKE_YUV_601(29, 29, 29),	/* 11.5% */
+		MAKE_YUV_601(19, 19, 19),	/* black */
+	};
+	unsigned int cs = yuv->chroma_stride;
+	unsigned int xsub = yuv->xsub;
+	unsigned int ysub = yuv->ysub;
+	unsigned int x;
+	unsigned int y;
+
+	/* Luma */
+	for (y = 0; y < height * 6 / 9; ++y) {
+		for (x = 0; x < width; ++x)
+			write_cc_xx_bpc_16(&y_mem[x * 2], bpc, msb,
+					   colors_top[x * 7 / width].y);
+		y_mem += stride;
+	}
+
+	for (; y < height * 7 / 9; ++y) {
+		for (x = 0; x < width; ++x)
+			write_cc_xx_bpc_16(&y_mem[x * 2], bpc, msb,
+					   colors_middle[x * 7 / width].y);
+		y_mem += stride;
+	}
+
+	for (; y < height; ++y) {
+		for (x = 0; x < width * 5 / 7; ++x)
+			write_cc_xx_bpc_16(&y_mem[x * 2], bpc, msb,
+					   colors_bottom[x * 4 / (width * 5 / 7)].y);
+		for (; x < width * 6 / 7; ++x)
+			write_cc_xx_bpc_16(&y_mem[x * 2], bpc, msb,
+					   colors_bottom[(x - width * 5 / 7) * 3 / (width / 7) + 4].y);
+		for (; x < width; ++x)
+			write_cc_xx_bpc_16(&y_mem[x * 2], bpc, msb,
+					   colors_bottom[7].y);
+		y_mem += stride;
+	}
+
+	/* Luma only format */
+	if (!u_mem || !v_mem)
+		return;
+
+	/* Chroma */
+	for (y = 0; y < height * 6 / 9; y += ysub) {
+		for (x = 0; x < width; x += xsub) {
+			write_cc_xx_bpc_16(&u_mem[x * 2], bpc, msb,
+					   colors_top[x * 7 / width].u);
+			write_cc_xx_bpc_16(&v_mem[x * 2], bpc, msb,
+					   colors_top[x * 7 / width].v);
+		}
+		u_mem += stride * cs / xsub;
+		v_mem += stride * cs / xsub;
+	}
+
+	for (; y < height * 7 / 9; y += ysub) {
+		for (x = 0; x < width; x += xsub) {
+			write_cc_xx_bpc_16(&u_mem[x * 2], bpc, msb,
+					   colors_middle[x * 7 / width].u);
+			write_cc_xx_bpc_16(&v_mem[x * 2], bpc, msb,
+					   colors_middle[x * 7 / width].v);
+		}
+		u_mem += stride * cs / xsub;
+		v_mem += stride * cs / xsub;
+	}
+
+	for (; y < height; y += ysub) {
+		for (x = 0; x < width * 5 / 7; x += xsub) {
+			write_cc_xx_bpc_16(&u_mem[x * 2], bpc, msb,
+					   colors_bottom[x * 4 / (width * 5 / 7)].u);
+			write_cc_xx_bpc_16(&v_mem[x * 2], bpc, msb,
+					   colors_bottom[x * 4 / (width * 5 / 7)].v);
+		}
+		for (; x < width * 6 / 7; x += xsub) {
+			write_cc_xx_bpc_16(&u_mem[x * 2], bpc, msb,
+					   colors_bottom[(x - width * 5 / 7) * 3 / (width / 7) + 4].u);
+			write_cc_xx_bpc_16(&v_mem[x * 2], bpc, msb,
+					   colors_bottom[(x - width * 5 / 7) * 3 / (width / 7) + 4].v);
+		}
+		for (; x < width; x += xsub) {
+			write_cc_xx_bpc_16(&u_mem[x * 2], bpc, msb,
+					   colors_bottom[7].u);
+			write_cc_xx_bpc_16(&v_mem[x * 2], bpc, msb,
+					   colors_bottom[7].v);
+		}
+		u_mem += stride * cs / xsub;
+		v_mem += stride * cs / xsub;
+	}
+}
+
 static void fill_smpte_yuv_planar_10bpp(const struct util_yuv_info *yuv,
 					unsigned char *y_mem,
 					unsigned char *uv_mem,
@@ -765,111 +902,6 @@ static void fill_smpte_yuv_planar_x403(
