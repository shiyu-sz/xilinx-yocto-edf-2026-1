+static void fill_tiles_yuv_planar_xx_bpc_16(const struct util_format_info *info,
+					    unsigned char *y_mem,
+					    unsigned char *u_mem,
+					    unsigned char *v_mem,
+					    unsigned int width,
+					    unsigned int height,
+					    unsigned int stride,
+					    unsigned char bpc,
+					    bool msb)
+{
+	assert(bpc >= 8 && bpc <= 16);
+
+	const struct util_yuv_info *yuv = &info->yuv;
+	unsigned int cs = yuv->chroma_stride;
+	unsigned int xsub = yuv->xsub;
+	unsigned int ysub = yuv->ysub;
+	unsigned int x;
+	unsigned int y;
+	unsigned short mask = msb ? ~(1 << (16 - bpc) - 1) : (1 << bpc) - 1;
+	unsigned short shift = msb ? 8 : bpc - 8;
+
+	for (y = 0; y < height; ++y) {
+		unsigned short *y_dst = (unsigned short *)y_mem;
+		unsigned short *u_dst = (unsigned short *)u_mem;
+		unsigned short *v_dst = (unsigned short *)v_mem;
+
+		for (x = 0; x < width; ++x) {
+			struct color_yuv color =
+				make_tiles_yuv_color(x, y, width);
+
+			y_dst[x] = ((unsigned int)color.y << shift) & mask;
+			if (u_dst)
+				u_dst[x/xsub*cs] = ((unsigned int)color.u << shift) & mask;
+			if (v_dst)
+				v_dst[x/xsub*cs] = ((unsigned int)color.v << shift) & mask;
+		}
+
+		y_mem += stride;
+		if ((y + 1) % ysub == 0) {
+			if (u_mem)
+				u_mem += stride * cs / xsub;
+			if (v_mem)
+				v_mem += stride * cs / xsub;
+		}
+	}
+}
