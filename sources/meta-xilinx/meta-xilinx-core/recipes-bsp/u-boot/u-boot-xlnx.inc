SUMMARY = "AMD Xilinx fork of Das U-Boot for Zynq, Zynq UltraScale+ \
MPSoC, Versal, Versal NET and MicroBlaze targets."
DESCRIPTION = "Das U-Boot bootloader built from the AMD Xilinx \
u-boot-xlnx tree, which carries the SoC and board ports (PSU init, \
FSBL hand-off, secure boot, RPU/APU SPL flows, ...) needed to boot AMD \
adaptive SoC and FPGA platforms."
require recipes-bsp/u-boot/u-boot-common.inc
require recipes-bsp/u-boot/u-boot.inc

DEPENDS += "bc-native dtc-native python3-setuptools-native bison-native xxd-native"

# RISC-V U-boot depends on opensbi
DEPENDS:append:riscv32 = " opensbi"
DEPENDS:append:riscv64 = " opensbi"

require u-boot-xlnx-common.inc
inherit shared-manifest

MANIFEST_COMPONENT_NAME ?= "u-boot"

SYSROOT_DIRS += "/boot"

BASE_DTS ?= "${@os.path.splitext(os.path.basename(d.getVar('CONFIG_DTFILE') or ''))[0] or 'system-top'}"
DTB_PATH ?= "boot/devicetree/"
DTB_FILE_NAME ?= ""

# This vairable is used for U-boot user specified dts from u-boot repo path
# u-boot-xlnx/arch/arm/dts/versal-vck190-revA-x-ebm-01-revA.dts.
# Note: .dts extension is not required for this variable settings.
# Example: UBOOT_USER_SPECIFIED_DTS = "versal-vck190-revA-x-ebm-01-revA"
UBOOT_USER_SPECIFIED_DTS ?= ""

EXTRA_OEMAKE += "${@'EXT_DTB=${RECIPE_SYSROOT}/${DTB_PATH}/${DTB_FILE_NAME}' if (d.getVar('DTB_FILE_NAME') != '' and d.getVar('UBOOT_USER_SPECIFIED_DTS') == '') else '' }"
EXTRA_OEMAKE += "${@'DEVICE_TREE=${UBOOT_USER_SPECIFIED_DTS}' if (d.getVar('UBOOT_USER_SPECIFIED_DTS') != '') else '' }"
EXTRA_OEMAKE:append:riscv32 = " ${@'OPENSBI=${RECIPE_SYSROOT}/share/opensbi/ilp32/generic/firmware/fw_dynamic.bin'}"
EXTRA_OEMAKE:append:riscv64 = " ${@'OPENSBI=${RECIPE_SYSROOT}/share/opensbi/lp64/generic/firmware/fw_dynamic.bin'}"

python __anonymous () {
    #check if there are any dtb providers
    providerdtb = d.getVar("PREFERRED_PROVIDER_virtual/dtb")
    if providerdtb:
       d.appendVarFlag('do_configure', 'depends', ' virtual/dtb:do_populate_sysroot')
       if d.getVar("DTB_FILE_NAME") is not None:
           d.setVar('DTB_FILE_NAME', d.getVar('BASE_DTS')+ '.dtb')
}

DEFAULT_ARCH_DTS_DIR = ""
DEFAULT_ARCH_DTS_DIR:arm = "arm"
DEFAULT_ARCH_DTS_DIR:aarch64 = "arm"
DEFAULT_ARCH_DTS_DIR:microblazeel = "microblaze"
DEFAULT_ARCH_DTS_DIR:riscv32 = "riscv"
DEFAULT_ARCH_DTS_DIR:riscv64 = "riscv"
ARCH_DTS_DIR ?= "${DEFAULT_ARCH_DTS_DIR}"

do_configure:prepend () {
    if [ -n "${UBOOT_USER_SPECIFIED_DTS}" ] && [ ! -f "${S}/arch/${ARCH_DTS_DIR}/dts/${UBOOT_USER_SPECIFIED_DTS}.dts" ]; then
        bbfatal "Uboot user specified dts (${UBOOT_USER_SPECIFIED_DTS}.dts) is not found in \
the${S}/arch/${ARCH_DTS_DIR}/dts directory, you need to patch dts file to u-boot source and use this configuration. \
For more details refer https://u-boot.readthedocs.io/en/latest/develop/devicetree/control.html#configuration "
    fi
}

# Split u-boot into .bin and .elf packages
# If the user just installs u-boot they get both
PACKAGES =+ "${PN}-bin ${PN}-elf"
RDEPENDS:${PN} = "${PN}-bin ${PN}-elf"
ALLOW_EMPTY:${PN} = "1"

SUMMARY:${PN}-bin = "${SUMMARY} - files in .bin format"
FILES:${PN}-bin = "/boot/u-boot*.bin"

SUMMARY:${PN}-elf = "${SUMMARY} - files in .elf format"
FILES:${PN}-elf = "/boot/u-boot*.elf"

UBOOTELF_NODTB_IMAGE ?= "u-boot-nodtb.elf"
UBOOTELF_NODTB_BINARY ?= "u-boot"
do_deploy:prepend() {
    cd ${B}

    if [ -f "${UBOOTELF_NODTB_BINARY}" ]; then
            install ${UBOOTELF_NODTB_BINARY} ${DEPLOYDIR}/${UBOOTELF_NODTB_IMAGE}
    fi

    #following lines are from uboot-sign.bbclass, vars are defined there
    if [ -e "${UBOOT_DTB_BINARY}" ]; then
            if [ "${UBOOT_SIGN_ENABLE}" = "0" ]; then
                    install ${UBOOT_DTB_BINARY} ${DEPLOYDIR}/${UBOOT_DTB_IMAGE}
            fi
            ln -sf ${UBOOT_DTB_IMAGE} ${DEPLOYDIR}/${UBOOT_DTB_BINARY}
            ln -sf ${UBOOT_DTB_IMAGE} ${DEPLOYDIR}/${UBOOT_DTB_SYMLINK}
    fi
    if [ -f "${UBOOT_NODTB_BINARY}" ]; then
            install ${UBOOT_NODTB_BINARY} ${DEPLOYDIR}/${UBOOT_NODTB_IMAGE}
            ln -sf ${UBOOT_NODTB_IMAGE} ${DEPLOYDIR}/${UBOOT_NODTB_SYMLINK}
            ln -sf ${UBOOT_NODTB_IMAGE} ${DEPLOYDIR}/${UBOOT_NODTB_BINARY}
    fi

    # In ZynqMP u-boot.dtb is generated by default but not for versal, Hence manually deploy.
    if [ "${SOC_FAMILY}" == "versal" -o "${SOC_FAMILY}" == "versal-net" ]; then
        if [ -f ${B}/arch/${DEFAULT_ARCH_DTS_DIR}/dts/${UBOOT_USER_SPECIFIED_DTS}.dtb ]; then
            install -Dm 0644 ${B}/arch/${DEFAULT_ARCH_DTS_DIR}/dts/${UBOOT_USER_SPECIFIED_DTS}.dtb ${DEPLOYDIR}/u-boot.dtb
        fi
    fi
}

# Output the generated ITB file. MicroBlaze-V platforms can use this ITB directly
# for TFTP, NOR flash(QSPI/OSPI) boot.
UBOOT_SPL_FITIMAGE ?= "u-boot"
UBOOT_SPL_FITIMAGE_SUFFIX ?= "itb"
UBOOT_SPL_FITIMAGE_IMAGE ?= "${UBOOT_SPL_FITIMAGE}-fitImage-${MACHINE}-${UBOOT_VERSION}.${UBOOT_SPL_FITIMAGE_SUFFIX}"
UBOOT_SPL_FITIMAGE_BINARY ?= "${UBOOT_SPL_FITIMAGE}.${UBOOT_SPL_FITIMAGE_SUFFIX}"
UBOOT_SPL_FITIMAGE_SYMLINK ?= "${UBOOT_SPL_FITIMAGE}-fitImage-${MACHINE}.${UBOOT_SPL_FITIMAGE_SUFFIX}"

# Some U-Boot builds generate an SPL (Second Program Loader) ELF only when
# SPL_REMAKE_ELF is enabled. This ELF is required for MicroBlaze-V use cases
# such as SPI flash boot, JTAG boot, and QEMU, and can also be used for
# debugging purposes.
SPL_ELF_SUFFIX ?= "elf"
SPL_ELF_DELIMITER  ?= "${@'.' if d.getVar("SPL_ELF_SUFFIX") else ''}"
SPL_ELFNAME ?= "${@os.path.basename(d.getVar("SPL_BINARY")).removesuffix('.bin') + SPL_ELF_DELIMITER + SPL_ELF_SUFFIX if d.getVar("SPL_BINARY") else ''}"
SPL_ELF_IMAGE ?= "${SPL_ELFNAME}-${MACHINE}-${UBOOT_VERSION}"
SPL_ELF_SYMLINK ?= "${SPL_ELFNAME}-${MACHINE}"

do_deploy:prepend:microblaze-v (){
    cd ${B}

    # Deploy u-boot.itb file
    if [ -f "${UBOOT_SPL_FITIMAGE_BINARY}" ]; then
            install ${UBOOT_SPL_FITIMAGE_BINARY} ${DEPLOYDIR}/${UBOOT_SPL_FITIMAGE_IMAGE}
            ln -sf ${UBOOT_SPL_FITIMAGE_IMAGE} ${DEPLOYDIR}/${UBOOT_SPL_FITIMAGE_BINARY}
            ln -sf ${UBOOT_SPL_FITIMAGE_IMAGE} ${DEPLOYDIR}/${UBOOT_SPL_FITIMAGE_SYMLINK}
    fi

    # Deploy the SPL ELF file if it exists
    if [ -f "spl/${SPL_ELFNAME}" ]; then
        install spl/${SPL_ELFNAME} ${DEPLOYDIR}/${SPL_ELF_IMAGE}
        ln -sf ${SPL_ELF_IMAGE} ${DEPLOYDIR}/${SPL_ELFNAME}
        ln -sf ${SPL_ELF_IMAGE} ${DEPLOYDIR}/${SPL_ELF_SYMLINK}
    fi
}
