From 84b2e62370435a27638318a5eecb86e256b11905 Mon Sep 17 00:00:00 2001
From: Parth Gajjar <parth.gajjar@amd.com>
Date: Mon, 6 Apr 2026 05:52:03 -0700
Subject: [PATCH] Fix GPU subsystem reboot failure with 6.18 kernel

Kernel 6.17 added of_genpd_sync_state() to the ZynqMP firmware driver,
which powers off unclaimed PM domains after boot. On subsystem reboot,
PD_GPU is not re-activated before hardware init, causing GPU register
reads to return zero (rawstat: 0x00000000).

Fixes:
- Add shutdown handler for clean teardown.
- Add pm_runtime_get_sync() before HW init to activate PD_GPU via genpd.
- Guard runtime PM callbacks with mali_subsystems_initialized flag.
- Release GPU reset on re-probe (left asserted by shutdown).
- Fix incorrect shrinker API usage for kernel 6.12+(shrinker_alloc/free).
- Replace deprecated flush_scheduled_work() with cancel_work_sync().

Upstream-Status: Inappropriate [Xilinx specific]
Signed-off-by: Parth Gajjar <parth.gajjar@amd.com>
---
 .../devicedrv/mali/linux/mali_kernel_linux.c  | 58 ++++++++++++++++++-
 .../mali/linux/mali_memory_os_alloc.c         | 36 ++++++++++--
 .../devicedrv/mali/linux/mali_memory_types.h  |  5 ++
 platform/arm/arm.c  | 29 +++++++---
 .../mali/platform/arm/arm_core_scaling.c      |  2 +-
 5 files changed, 113 insertions(+), 17 deletions(-)

diff --git a/linux/mali_kernel_linux.c b/linux/mali_kernel_linux.c
index d312ea7..44b0331 100644
--- a/linux/mali_kernel_linux.c
+++ b/linux/mali_kernel_linux.c
@@ -26,6 +26,7 @@
 #include <linux/of.h>
 #include <linux/clk.h>
 #include <linux/regulator/consumer.h>
+#include <linux/pm_runtime.h>
 
 #include <linux/mali/mali_utgard.h>
 #include "mali_kernel_common.h"
@@ -47,6 +48,9 @@
 #endif
 
 #if defined(CONFIG_ARCH_ZYNQMP)
+#include <linux/firmware/xlnx-zynqmp.h>
+#include <dt-bindings/power/xlnx-zynqmp-power.h>
+
 /* Initialize variables for clocks */
 struct clk *clk_bus;
 struct clk *clk_core;
@@ -169,6 +173,9 @@ EXPORT_SYMBOL(mali_get_user_setting);
 
 static char mali_dev_name[] = "mali"; /* should be const, but the functions we call requires non-cost */
 
+/* Flag to track if Mali subsystems are initialized - used to guard runtime PM callbacks */
+static int mali_subsystems_initialized = 0;
+
 /* This driver only supports one Mali device, and this variable stores this single platform device */
 struct platform_device *mali_platform_device = NULL;
 
@@ -192,6 +199,7 @@ static void mali_remove(struct platform_device *pdev);
 #else
 static int mali_remove(struct platform_device *pdev);
 #endif
+static void mali_shutdown(struct platform_device *pdev);
 
 static int mali_driver_suspend_scheduler(struct device *dev);
 static int mali_driver_resume_scheduler(struct device *dev);
@@ -254,6 +262,7 @@ MODULE_DEVICE_TABLE(of, base_dt_ids);
 static struct platform_driver mali_platform_driver = {
 	.probe  = mali_probe,
 	.remove = mali_remove,
+	.shutdown = mali_shutdown,
 #if (LINUX_VERSION_CODE < KERNEL_VERSION(2, 6, 29))
 	.pm = &mali_dev_ext_pm_ops,
 #endif
@@ -551,7 +560,6 @@ static int mali_probe(struct platform_device *pdev)
 #ifdef CONFIG_MALI_DEVFREQ
 	struct mali_device *mdev;
 #endif
-
 	MALI_DEBUG_PRINT(2, ("mali_probe(): Called for platform device %s\n", pdev->name));
 
 	if (NULL != mali_platform_device) {
@@ -567,8 +575,9 @@ static int mali_probe(struct platform_device *pdev)
 	err = mali_platform_device_init(mali_platform_device);
 	if (0 != err) {
 		MALI_PRINT_ERROR(("mali_probe(): Failed to initialize platform device."));
+		mali_platform_device_deinit(mali_platform_device);
 		mali_platform_device = NULL;
-		return -EFAULT;
+		return err;
 	}
 #endif
 
@@ -641,8 +650,21 @@ static int mali_probe(struct platform_device *pdev)
 	if (err)
 		return err;
 	if (_MALI_OSK_ERR_OK == _mali_osk_wq_init()) {
+#ifdef CONFIG_PM_RUNTIME
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(2, 6, 37))
+		pm_runtime_set_autosuspend_delay(&pdev->dev, 1000);
+		pm_runtime_use_autosuspend(&pdev->dev);
+#endif
+		pm_runtime_enable(&pdev->dev);
+		pm_runtime_get_sync(&pdev->dev);
+#endif
 		/* Initialize the Mali GPU HW specified by pdev */
 		if (_MALI_OSK_ERR_OK == mali_initialize_subsystems()) {
+			mali_subsystems_initialized = 1;
+#ifdef CONFIG_PM_RUNTIME
+			pm_runtime_mark_last_busy(&pdev->dev);
+			pm_runtime_put_autosuspend(&pdev->dev);
+#endif
 			/* Register a misc device (so we are accessible from user space) */
 			err = mali_miscdevice_register(pdev);
 			if (0 == err) {
@@ -663,6 +685,10 @@ static int mali_probe(struct platform_device *pdev)
 			mali_terminate_subsystems();
 		} else {
 			MALI_PRINT_ERROR(("mali_probe(): Failed to initialize Mali device driver."));
+#ifdef CONFIG_PM_RUNTIME
+			pm_runtime_put_sync(&pdev->dev);
+			pm_runtime_disable(&pdev->dev);
+#endif
 		}
 		_mali_osk_wq_term();
 	}
@@ -751,6 +777,20 @@ static int mali_remove(struct platform_device *pdev)
 #endif
 }
 
+/* Put GPU into a known reset state for clean subsystem reboot */
+static void mali_shutdown(struct platform_device *pdev)
+{
+	mali_subsystems_initialized = 0;
+	mali_pm_os_suspend(MALI_TRUE);
+
+#if defined(CONFIG_ARCH_ZYNQMP)
+	zynqmp_pm_reset_assert(ZYNQMP_PM_RESET_GPU, PM_RESET_ACTION_ASSERT);
+	zynqmp_pm_release_node(PD_GPU);
+#endif
+
+	mali_disable_clk();
+}
+
 static int mali_miscdevice_register(struct platform_device *pdev)
 {
 	int err;
@@ -838,6 +878,13 @@ static int mali_driver_runtime_suspend(struct device *dev)
 		return -ENODEV;
 #endif
 
+	/* Only call Mali PM if subsystems are initialized */
+	if (!mali_subsystems_initialized) {
+		MALI_DEBUG_PRINT(2, ("Runtime suspend: Mali not initialized, just disabling clocks\n"));
+		mali_disable_clk();
+		return 0;
+	}
+
 	if (MALI_TRUE == mali_pm_runtime_suspend()) {
 		/* Tracing the frequency and voltage after mali is suspended */
 		_mali_osk_profiling_add_event(MALI_PROFILING_EVENT_TYPE_SINGLE |
@@ -868,6 +915,13 @@ static int mali_driver_runtime_resume(struct device *dev)
 	err = mali_enable_clk();
 	if (err)
 		return err;
+
+	/* Only call Mali PM if subsystems are initialized */
+	if (!mali_subsystems_initialized) {
+		MALI_DEBUG_PRINT(2, ("Runtime resume: Mali not initialized, just enabled clocks\n"));
+		return 0;
+	}
+
 #ifdef CONFIG_MALI_DEVFREQ
 	struct mali_device *mdev = dev_get_drvdata(dev);
 	if (!mdev)
diff --git a/linux/mali_memory_os_alloc.c b/linux/mali_memory_os_alloc.c
index b96900f..d842016 100644
--- a/linux/mali_memory_os_alloc.c
+++ b/linux/mali_memory_os_alloc.c
@@ -16,6 +16,7 @@
 #include <linux/version.h>
 #include <linux/platform_device.h>
 #include <linux/workqueue.h>
+#include <linux/rcupdate.h>
 
 #include "mali_osk.h"
 #include "mali_memory.h"
@@ -57,13 +58,17 @@ struct mali_mem_os_allocator mali_mem_os_allocator = {
 	.allocated_pages = ATOMIC_INIT(0),
 	.allocation_limit = 0,
 
-#if LINUX_VERSION_CODE < KERNEL_VERSION(3, 12, 0)
-	.shrinker.shrink = mali_mem_os_shrink,
-#else
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 7, 0)
+	/* Shrinker will be dynamically allocated in mali_mem_os_init() */
+	.shrinker = NULL,
+#elif LINUX_VERSION_CODE >= KERNEL_VERSION(3, 12, 0)
 	.shrinker.count_objects = mali_mem_os_shrink_count,
 	.shrinker.scan_objects = mali_mem_os_shrink,
-#endif
 	.shrinker.seeks = DEFAULT_SEEKS,
+#else
+	.shrinker.shrink = mali_mem_os_shrink,
+	.shrinker.seeks = DEFAULT_SEEKS,
+#endif
 #if LINUX_VERSION_CODE >= KERNEL_VERSION(3, 7, 0)
 	.timed_shrinker = __DELAYED_WORK_INITIALIZER(mali_mem_os_allocator.timed_shrinker, mali_mem_os_trim_pool, TIMER_DEFERRABLE),
 #elif LINUX_VERSION_CODE >= KERNEL_VERSION(2, 6, 38)
@@ -803,7 +808,16 @@ _mali_osk_errcode_t mali_mem_os_init(void)
 
 
 #if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 7, 0)
-	shrinker_register(&mali_mem_os_allocator.shrinker);
+	mali_mem_os_allocator.shrinker = shrinker_alloc(0, "mali-mem");
+	if (!mali_mem_os_allocator.shrinker) {
+		destroy_workqueue(mali_mem_os_allocator.wq);
+		mali_mem_os_allocator.wq = NULL;
+		return _MALI_OSK_ERR_NOMEM;
+	}
+	mali_mem_os_allocator.shrinker->count_objects = mali_mem_os_shrink_count;
+	mali_mem_os_allocator.shrinker->scan_objects = mali_mem_os_shrink;
+	mali_mem_os_allocator.shrinker->seeks = DEFAULT_SEEKS;
+	shrinker_register(mali_mem_os_allocator.shrinker);
 #elif LINUX_VERSION_CODE >= KERNEL_VERSION(5, 16, 0)
 	register_shrinker(&mali_mem_os_allocator.shrinker, "mali");
 #else
@@ -816,7 +830,17 @@ void mali_mem_os_term(void)
 {
 	struct mali_page_node *m_page, *m_tmp;
 #if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 7, 0)
-	shrinker_free(&mali_mem_os_allocator.shrinker);
+	if (mali_mem_os_allocator.shrinker) {
+		shrinker_free(mali_mem_os_allocator.shrinker);
+		mali_mem_os_allocator.shrinker = NULL;
+		/*
+		 * Wait for RCU callbacks to complete.
+		 * shrinker_free() uses RCU to free the shrinker structure,
+		 * and we must wait for this to complete to avoid use-after-free
+		 * issues with the shrinker infrastructure.
+		 */
+		rcu_barrier();
+	}
 #else
 	unregister_shrinker(&mali_mem_os_allocator.shrinker);
 #endif
diff --git a/linux/mali_memory_types.h b/linux/mali_memory_types.h
index 4d246db..08afac5 100644
--- a/linux/mali_memory_types.h
+++ b/linux/mali_memory_types.h
@@ -12,6 +12,7 @@
 #define __MALI_MEMORY_TYPES_H__
 
 #include <linux/mm.h>
+#include <linux/version.h>
 
 #if defined(CONFIG_MALI400_UMP)
 #include "ump_kernel_interface.h"
@@ -153,7 +154,11 @@ struct mali_mem_os_allocator {
 	atomic_t allocated_pages;
 	size_t allocation_limit;
 
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 7, 0)
+	struct shrinker *shrinker;
+#else
 	struct shrinker shrinker;
+#endif
 	struct delayed_work timed_shrinker;
 	struct workqueue_struct *wq;
 };
diff --git a/platform/arm/arm.c b/platform/arm/arm.c
index e468263..ccb0d3d 100644
--- a/platform/arm/arm.c
+++ b/platform/arm/arm.c
@@ -26,6 +26,10 @@
 #include "mali_kernel_common.h"
 #include <linux/dma-mapping.h>
 #include <linux/moduleparam.h>
+#include <linux/delay.h>
+#if defined(CONFIG_ARCH_ZYNQMP)
+#include <linux/firmware/xlnx-zynqmp.h>
+#endif
 
 #include "arm_core_scaling.h"
 #include "mali_executor.h"
@@ -521,6 +525,14 @@ int mali_platform_device_init(struct platform_device *device)
 	MALI_DEBUG_PRINT(4, ("Registering Zynq/ZynqMP Mali-400 device\n"));
 	num_pp_cores = 2;
 
+#if defined(CONFIG_ARCH_ZYNQMP)
+	/* Release GPU reset — mali_shutdown() leaves it asserted.
+	 * Power domain is handled by pm_runtime via genpd (DT power-domains).
+	 */
+	zynqmp_pm_reset_assert(ZYNQMP_PM_RESET_GPU, PM_RESET_ACTION_RELEASE);
+	mdelay(10);
+#endif /* CONFIG_ARCH_ZYNQMP */
+
 #endif
 
 	/* After kernel 3.15 device tree will default set dev
@@ -539,15 +551,11 @@ int mali_platform_device_init(struct platform_device *device)
 	err = platform_device_add_data(device, &mali_gpu_data, sizeof(mali_gpu_data));
 
 	if (0 == err) {
-#ifdef CONFIG_PM_RUNTIME
-#if (LINUX_VERSION_CODE >= KERNEL_VERSION(2, 6, 37))
-		pm_runtime_set_autosuspend_delay(&(device->dev), 1000);
-		pm_runtime_use_autosuspend(&(device->dev));
-#endif
-		pm_runtime_enable(&(device->dev));
-#endif
+		/* pm_runtime is enabled later in mali_probe() after subsystem init */
 		MALI_DEBUG_ASSERT(0 < num_pp_cores);
 		mali_core_scaling_init(num_pp_cores);
+	} else {
+		return err;
 	}
 
 #if defined(CONFIG_MALI_DEVFREQ) && defined(CONFIG_DEVFREQ_THERMAL)
@@ -558,7 +566,12 @@ int mali_platform_device_init(struct platform_device *device)
 				     PTR_ERR(gpu_tz)));
 		gpu_tz = NULL;
 
-		err =  -EPROBE_DEFER;
+		/* Clean up what we initialized before returning error */
+		mali_core_scaling_term();
+#ifdef CONFIG_PM_RUNTIME
+		pm_runtime_disable(&(device->dev));
+#endif
+		err = -EPROBE_DEFER;
 	}
 #endif
 
diff --git a/platform/arm/arm_core_scaling.c b/platform/arm/arm_core_scaling.c
index 8818100..1a28632 100644
--- a/platform/arm/arm_core_scaling.c
+++ b/platform/arm/arm_core_scaling.c
@@ -84,7 +84,7 @@ void mali_core_scaling_sync(int num_cores)
 
 void mali_core_scaling_term(void)
 {
-	flush_scheduled_work();
+	cancel_work_sync(&wq_work);
 }
 
 #define PERCENT_OF(percent, max) ((int) ((percent)*(max)/100.0 + 0.5))
-- 
2.44.4

